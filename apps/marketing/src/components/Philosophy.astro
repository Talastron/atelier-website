---
// apps/marketing/src/components/Philosophy.astro
//
// The closing moment of the home page. This is the page's final argument:
// after the hero, the demos, and the toolkit grid, the visitor lands here
// to decide whether to step inside. Treated as an editorial dark card so
// it reads as a chapter ending, not a sales banner.
//
// Two CTAs by design:
//   - Primary  → /pricing (where "The Keys to Atelier" lives)
//   - Secondary → EDIT_URL  (sign-in path for returning members, no friction)
//
// Replaces the prior "Buy less. Wear better." treatment, which (a) used
// a generic fashion-industry headline rather than brand voice, and (b)
// pointed the only CTA directly at the app login, sending unsubscribed
// visitors into a sign-in wall instead of checkout.
import { BrassRule } from '@atelier/ui';
import { EDIT_URL } from '../config.ts';
import { ChevronRight } from 'lucide-react';
---

<!-- Container constrains the dark card to the same 1280px width as Hero + Features. -->
<div
  class="mx-auto mb-24"
  style="max-width: var(--atelier-container-max); padding-inline: var(--atelier-page-padding);"
>
  <section
    class="relative overflow-hidden rounded-[3rem]"
    style={`background: linear-gradient(160deg, var(--atelier-ink) 0%, #292524 100%); color: #ffffff; padding-block: clamp(4rem, 7vw, 6rem); padding-inline: clamp(2rem, 5vw, 4rem); box-shadow: 0 60px 140px -40px rgba(28, 25, 23, 0.45);`}
  >
    {/* Decorative AtelierMark hanger — the brand's actual mark, at low
        opacity in the bottom-right. Just the wire-hanger silhouette and
        brass charm, no dark square background, so it floats on the
        gradient rather than blocking it. Visual rhyme with the nav logo,
        the footer brand block, and the sidebar in the studio. */}
    <div
      aria-hidden="true"
      class="absolute pointer-events-none"
      style="right: -1.5rem; bottom: -2rem; opacity: 0.12; transform: rotate(-14deg);"
    >
      <svg
        width="320"
        height="320"
        viewBox="0 0 256 256"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        {/* Hanger silhouette — the same path as AtelierMark but stroked
            in white so it reads on the dark gradient instead of black on cream. */}
        <g
          fill="none"
          stroke="#ffffff"
          stroke-width="7"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M 160 60 Q 160 44 144 44 Q 128 44 128 58 L 128 110" />
          <path d="M 128 110 L 62 184 L 194 184 Z" />
        </g>
        {/* Brass charm thread + bead — same as the footer/nav/sidebar mark */}
        <line
          x1="128"
          y1="184"
          x2="128"
          y2="206"
          stroke="#D4B378"
          stroke-width="1.5"
          stroke-linecap="round"
          opacity="0.8"
        />
        <circle cx="128" cy="212" r="5" fill="#D4B378" />
      </svg>
    </div>

    {/* Soft brass glow behind the headline — gives the dark card warmth */}
    <div
      aria-hidden="true"
      class="absolute pointer-events-none"
      style="top: 0; left: 50%; transform: translateX(-50%); width: 60%; height: 50%; background: radial-gradient(ellipse at center, rgba(212, 179, 120, 0.08) 0%, transparent 70%);"
    />

    <div class="relative z-10 max-w-3xl mx-auto text-center">
      {/* Editorial mast — same motif as the Hero and Pricing hero */}
      <div class="flex items-center justify-center gap-4 mb-8">
        <BrassRule client:load />
        <span
          class="text-[10px] uppercase font-medium"
          style="letter-spacing: 0.32em; color: var(--atelier-brass-300);"
        >
          An Invitation · MMXXVI
        </span>
        <BrassRule client:load />
      </div>

      {/* Headline — short, declarative, brand-voice. Period at the end so
          it lands as a statement of fact. */}
      <h2
        class="mb-8"
        style="font-family: var(--atelier-font-display); font-size: clamp(2.25rem, 5vw, 4rem); line-height: 1.02; letter-spacing: -0.015em; color: #ffffff;"
      >
        An <em style="font-weight: 400;">atelier</em> of your own.
      </h2>

      {/* Considered subhead — written as a closing argument, not a pitch.
          Three short clauses, each one a thing membership unlocks. */}
      <p
        class="mx-auto mb-8"
        style="color: rgba(255,255,255,0.7); font-size: clamp(1rem, 1.3vw, 1.1875rem); line-height: 1.7; max-width: 48ch;"
      >
        A private stylist on call. Your considered closet, finally on the page.
        The small luxuries that turn a wardrobe into a practice.
      </p>

      {/* Trial line — pill format, brass on dark. Truncated to just
          '14-day trial' since Lemon Squeezy collects card details at
          checkout, so claiming 'no card required' would be dishonest. */}
      <p
        class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full mb-10"
        style="background: rgba(212, 179, 120, 0.12); border: 1px solid rgba(212, 179, 120, 0.25); color: var(--atelier-brass-300); font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; font-weight: 600;"
      >
        <span
          aria-hidden="true"
          style="width: 5px; height: 5px; border-radius: 50%; background: var(--atelier-brass-300);"
        />
        14-day trial
      </p>

      {/* Two CTAs — primary brass to /pricing (where the Keys live),
          secondary ghost link to the app for returning members. */}
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/pricing"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-full text-base font-semibold transition-all hover:opacity-90 active:scale-[0.98]"
          style="background: var(--atelier-brass-300); color: var(--atelier-stone-900); letter-spacing: 0.04em; box-shadow: 0 12px 32px -10px rgba(212, 179, 120, 0.45);"
        >
          Begin curating
          <ChevronRight size={16} strokeWidth={1.75} client:load />
        </a>
        <a
          href={EDIT_URL}
          class="inline-flex items-center gap-2 px-6 py-3 text-sm transition-colors group"
          style="color: rgba(255,255,255,0.7);"
        >
          Sign in
          <span
            class="transition-transform group-hover:translate-x-1"
            style="color: var(--atelier-brass-300); display: inline-block;"
          >
            →
          </span>
        </a>
      </div>
    </div>
  </section>
</div>
