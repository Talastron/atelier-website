---
// apps/marketing/src/components/JournalRail.astro
//
// "Latest from the Journal" rail for the home page. Replaces the prior
// Features grid (which read SaaS-by-default — six icon cards in a 3-col
// arrangement) with editorial preview cards for the three most-recent
// journal entries.
//
// Why this is the higher-leverage section: the Journal is Atelier's
// strongest editorial weapon — sustained writing in the brand voice
// proves the voice on the marketing site is real, not surface dressing.
// Burying it at /journal (only linked from nav + footer) wasted that
// proof. Surfacing the three latest essays in the home-page rhythm is
// the cheapest possible upgrade to the page's trust signal.
//
// Cards: editorial layout (date + kind eyebrow + title + standfirst).
// Hover state: brass hairline draws beneath the title, same micro-
// interaction as the mobile nav and footer Return-to-top.
import { BrassRule } from '@atelier/ui';
import { getCollection } from 'astro:content';
import { ChevronRight } from 'lucide-react';

const all = (await getCollection('journal', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const latest = all.slice(0, 3);

function fmtDate(d: Date) {
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<section
  style="padding-block: clamp(5rem, 9vw, 7rem); padding-inline: var(--atelier-page-padding); background: var(--atelier-cream);"
>
  <div
    class="mx-auto"
    style="max-width: var(--atelier-container-max);"
  >
    {/* Section header */}
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12 md:mb-16">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <BrassRule client:load />
          <p
            class="text-[10px] uppercase font-medium"
            style="letter-spacing: 0.32em; color: var(--atelier-brass-600);"
          >
            From the Journal
          </p>
        </div>
        <h2
          style="font-family: var(--atelier-font-display); font-size: clamp(2rem, 3.5vw, 3rem); line-height: 1.05; letter-spacing: -0.01em; color: var(--atelier-stone-900); max-width: 22ch;"
        >
          <em style="font-weight: 400;">Essays &amp; notes</em> on the considered wardrobe.
        </h2>
      </div>
      <a
        href="/journal"
        class="journal-rail-all inline-flex items-center gap-2 text-[11px] uppercase font-medium self-start md:self-end shrink-0"
        style="letter-spacing: 0.28em; color: var(--atelier-stone-700);"
      >
        Read the Journal
        <ChevronRight size={12} strokeWidth={1.75} client:load />
      </a>
    </div>

    {/* Three preview cards. Top + bottom hairlines on the rail give it
        the editorial newspaper-rail feel — each card sits as a column
        between two horizontal rules. */}
    <div
      class="grid grid-cols-1 md:grid-cols-3"
      style="border-top: 1px solid var(--atelier-stone-200); border-bottom: 1px solid var(--atelier-stone-200);"
    >
      {latest.map((post, i) => (
        <a
          href={`/journal/${post.slug}`}
          class={`journal-card group flex flex-col py-10 md:py-12 ${
            i > 0 ? 'md:border-l border-stone-200' : ''
          }`}
          style={`padding-inline: ${i === 0 ? '0 1.5rem' : '1.5rem'}; ${
            i > 0 ? 'border-top: 1px solid var(--atelier-stone-200);' : ''
          }`}
        >
          {/* Meta line — kind + date */}
          <div class="flex items-center gap-3 mb-5">
            <span
              aria-hidden="true"
              style="display: inline-block; width: 18px; height: 1.5px; background: var(--atelier-brass-300);"
            />
            <p
              class="text-[10px] uppercase font-medium"
              style="letter-spacing: 0.28em; color: var(--atelier-brass-600);"
            >
              {post.data.kind === 'essay' ? 'Essay' : 'Note'}
            </p>
            <span
              class="text-[10px] uppercase"
              style="letter-spacing: 0.18em; color: var(--atelier-stone-400);"
            >
              {fmtDate(post.data.date)}
            </span>
          </div>

          {/* Title — large display serif. Brass hairline draws on hover. */}
          <h3
            class="journal-card-title mb-4"
            style="font-family: var(--atelier-font-display); font-size: clamp(1.375rem, 2vw, 1.75rem); line-height: 1.1; letter-spacing: -0.01em; color: var(--atelier-stone-900);"
          >
            {post.data.title}
          </h3>

          {/* Standfirst — the opening promise of the piece */}
          <p
            class="flex-1"
            style="font-size: 0.9375rem; line-height: 1.65; color: var(--atelier-stone-600);"
          >
            {post.data.description}
          </p>

          {/* Read on cue */}
          <span
            class="inline-flex items-center gap-1.5 text-[10px] uppercase font-medium mt-6"
            style="letter-spacing: 0.28em; color: var(--atelier-stone-700);"
          >
            Read on
            <span
              class="transition-transform group-hover:translate-x-1"
              style="color: var(--atelier-brass-600); display: inline-block;"
            >→</span>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  /* Title brass-hairline-on-hover — same vocabulary as the mobile nav
     and the footer Return-to-top. Underline grows from beneath the
     title text, brass-600, 1.5px. */
  .journal-card-title {
    display: inline-block;
    position: relative;
    padding-bottom: 0.35rem;
  }
  .journal-card-title::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 0;
    height: 1.5px;
    background: var(--atelier-brass-600);
    transition: width 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .journal-card:hover .journal-card-title::after,
  .journal-card:focus-visible .journal-card-title::after {
    width: 100%;
  }

  /* "Read the Journal" link — same hairline-on-hover */
  .journal-rail-all {
    position: relative;
    padding-bottom: 0.4rem;
    transition: color 200ms ease;
  }
  .journal-rail-all::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 0;
    height: 1.5px;
    background: var(--atelier-brass-600);
    transition: width 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .journal-rail-all:hover,
  .journal-rail-all:focus-visible {
    color: var(--atelier-stone-900);
  }
  .journal-rail-all:hover::after,
  .journal-rail-all:focus-visible::after {
    width: 100%;
  }
</style>
