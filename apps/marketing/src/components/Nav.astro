---
// apps/marketing/src/components/Nav.astro
//
// Site navigation, two states:
//   - Desktop (md+): horizontal bar with logo + 3 nav links + sign in + brass CTA
//   - Mobile (<md): logo + brass CTA + hamburger trigger. Tapping the trigger
//                   opens a full-screen overlay menu with editorial typography.
//
// The mobile overlay is a fixed-position panel that fades in over the page.
// Contents are stacked vertically with generous rhythm — large display-serif
// nav links, an Open Studio CTA at the bottom, and a quiet colophon line.
// Closes via the X button, ESC key, or the secondary "Close" link. Body
// scroll is locked while the menu is open so the page doesn't drift behind it.
//
// All interactivity is vanilla JS in the inline script block at the
// bottom of this file — no React hydration needed for a simple toggle.
import { AtelierMark } from '@atelier/ui';
import { EDIT_URL, SITE } from '../config.ts';
import { Menu, X } from 'lucide-react';

const NAV_LINKS = [
  { label: 'About', href: '/about' },
  { label: 'Studio', href: '/studio' },
  { label: 'Journal', href: '/journal' },
  { label: 'Pricing', href: '/pricing' },
];

// Active-link detection — strip trailing slash off Astro.url.pathname so '/about'
// and '/about/' both match the same link. The brass hairline is drawn statically
// on whichever link the visitor is currently sitting on; on hover, links draw
// the same hairline from centre outward (see .desktop-nav-link::after below).
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(`${href}/`);
};
---

<nav
  class="fixed top-0 left-0 right-0 z-50 bg-cream/90 backdrop-blur-md border-b"
  style="border-color: rgba(212, 179, 120, 0.18);"
>
  <div
    class="mx-auto h-20 flex items-center justify-between gap-6"
    style="max-width: var(--atelier-container-max); padding-inline: var(--atelier-page-padding);"
  >
    {/* Logo — hanger mark + wordmark + editorial kicker on desktop.
        Structure: outer flex is items-center so the hanger sentinel centres
        with the wordmark text block (SVGs don't have a typographic baseline,
        so items-baseline on the outer throws the icon off). The wordmark +
        kicker sit inside an inner flex with items-baseline so 'est. MMXXVI'
        hangs at the wordmark's baseline like a typeset signature. The full
        stop on 'Atelier.' is set in brass — the wordmark's signature
        flourish, consistent with the rest of the brand's typesetting. */}
    <a href="/" class="flex items-center gap-3 shrink-0">
      <AtelierMark size={32} playOnce client:load />
      <div class="flex items-baseline gap-3">
        <span class="font-display text-2xl tracking-tight" style="line-height: 1;">
          Atelier<span style="color: var(--atelier-brass-600);">.</span>
        </span>
        <span
          class="hidden md:inline-block italic font-display"
          style="font-size: 0.6875rem; color: var(--atelier-stone-500); letter-spacing: 0.05em; line-height: 1;"
        >
          est. MMXXVI
        </span>
      </div>
    </a>

    {/* Desktop nav links (md+) — each carries a brass hairline beneath that
        draws statically on the active page and from centre outward on hover.
        Same micro-interaction as the mobile overlay, ported to desktop so
        brass appears in the bar at all times (previously the bar had no brass
        — the brand's signature accent was missing from its most-seen surface). */}
    <div class="hidden md:flex items-center gap-8 text-sm">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class:list={['desktop-nav-link', { 'is-active': isActive(link.href) }]}
        >
          {link.label}
        </a>
      ))}
      {/* Privacy in the top bar (not just the footer) so the link to our
          privacy policy is reachable above the fold — Google OAuth verification
          wants an "easily accessible" privacy link on the homepage. */}
      <a
        href="/legal/privacy/"
        class:list={['desktop-nav-link', { 'is-active': isActive('/legal/privacy') }]}
      >
        Privacy
      </a>
    </div>

    {/* Right cluster — one CTA only on desktop. The previous 'Sign In' +
        'Open Studio' duo was the most SaaS-coded pattern on the site
        (standard Stripe/Linear/Notion header). 'Open Studio' covers both
        new and returning users; the app's auth handles both states. The
        mobile overlay still surfaces 'Sign in to your studio' as a
        secondary link, since the overlay has the room for it. */}
    <div class="flex items-center gap-4 shrink-0">
      {/* Open Studio CTA (desktop only — hidden on mobile to give the hamburger
          full prominence and keep the bar uncluttered). The .studio-cta class
          carries the dark base shadow at rest and a brass-tinted glow on
          hover; see <style> block below. */}
      <a
        href={EDIT_URL}
        class="studio-cta hidden md:inline-flex bg-stone-900 text-white px-6 py-2.5 rounded-full text-sm font-medium hover:bg-stone-700 active:scale-95"
      >
        Open Studio
      </a>

      {/* Mobile menu trigger (<md only) */}
      <button
        id="mobile-menu-trigger"
        type="button"
        class="md:hidden flex items-center gap-2 px-3 py-2 -mr-2"
        aria-label="Open menu"
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <span
          class="text-[10px] uppercase font-medium text-stone-700"
          style="letter-spacing: 0.28em;"
        >
          Menu
        </span>
        <Menu size={18} strokeWidth={1.5} client:load />
      </button>
    </div>
  </div>
</nav>

{/* ──────────────────────────────────────────────────────────────────────
    MOBILE MENU OVERLAY
    Full-screen, cream background, editorial typography. Visible only on
    mobile (md:hidden). Fades in via [data-open="true"] attribute set by
    the script below.
    ────────────────────────────────────────────────────────────────── */}
<div
  id="mobile-menu"
  class="md:hidden fixed inset-0 z-[60] flex flex-col"
  style="background: var(--atelier-cream);"
  data-open="false"
  aria-hidden="true"
>
  {/* Header — logo + close button, mirroring the main nav bar so the
      transition is visually continuous */}
  <header
    class="flex items-center justify-between h-20 border-b border-stone-200/60"
    style="padding-inline: var(--atelier-page-padding);"
  >
    <a href="/" class="flex items-center gap-3 shrink-0" data-mobile-link>
      <AtelierMark size={32} playOnce client:load />
      <span class="font-display text-2xl tracking-tight">
        Atelier<span style="color: var(--atelier-brass-600);">.</span>
      </span>
    </a>
    <button
      id="mobile-menu-close"
      type="button"
      class="flex items-center gap-2 px-3 py-2 -mr-2"
      aria-label="Close menu"
    >
      <span
        class="text-[10px] uppercase font-medium text-stone-700"
        style="letter-spacing: 0.28em;"
      >
        Close
      </span>
      <X size={18} strokeWidth={1.5} client:load />
    </button>
  </header>

  {/* Main nav links — large, display serif, vertically centered */}
  <div
    class="flex-1 flex flex-col justify-center"
    style="padding-inline: var(--atelier-page-padding); padding-block: 2rem;"
  >
    <ul class="flex flex-col items-center gap-7">
      {NAV_LINKS.map((link, i) => (
        <li>
          <a
            href={link.href}
            data-mobile-link
            class="mobile-nav-link tracking-tight"
            style={`animation-delay: ${100 + i * 70}ms; font-family: var(--atelier-font-display); font-size: clamp(2.25rem, 9vw, 3rem); line-height: 1; color: var(--atelier-stone-900); letter-spacing: -0.01em;`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>

  {/* Footer — account actions + colophon. Sits at the bottom as a quiet
      closing chord rather than a separate region */}
  <footer
    class="border-t border-stone-200/60"
    style="padding-inline: var(--atelier-page-padding); padding-block: 1.75rem; display: flex; flex-direction: column; gap: 1.5rem;"
  >
    {/* Sign In + Open Studio — secondary then primary */}
    <div class="flex flex-col gap-3">
      <a
        href={EDIT_URL}
        data-mobile-link
        class="text-center text-sm font-medium text-stone-600 py-3"
      >
        Sign in to your studio
      </a>
      <a
        href={EDIT_URL}
        data-mobile-link
        class="inline-flex items-center justify-center gap-2 bg-stone-900 text-white px-8 py-4 rounded-full text-sm font-semibold transition-all hover:opacity-90 active:scale-[0.98]"
        style="letter-spacing: 0.04em; box-shadow: 0 12px 32px -10px rgba(28, 25, 23, 0.3);"
      >
        Open Studio
      </a>
    </div>

    {/* Closing colophon — brass dots + address. Same vocabulary as
        the footer signature so the menu feels of-a-piece with the page */}
    <div class="flex flex-col items-center gap-2.5 pt-2">
      <div class="flex items-center gap-2" aria-hidden="true">
        <span style="display: inline-block; width: 3px; height: 3px; border-radius: 50%; background: var(--atelier-brass-300);" />
        <span style="display: inline-block; width: 3px; height: 3px; border-radius: 50%; background: var(--atelier-brass-600);" />
        <span style="display: inline-block; width: 3px; height: 3px; border-radius: 50%; background: var(--atelier-brass-300);" />
      </div>
      <p
        class="text-center text-[10px] uppercase font-medium"
        style="letter-spacing: 0.32em; color: var(--atelier-stone-500);"
      >
        The Long Barn &middot; Cobham &middot; Surrey
      </p>
    </div>
  </footer>
</div>

<style>
  /* Desktop nav links — brass hairline beneath each. Static on the active
     page (so visitors always know where they are); draws from centre outward
     on hover (matching the mobile-overlay micro-interaction). Same timing
     function as the mobile version — keeps the site's hover vocabulary
     consistent across breakpoints.

     Typography: font-weight reduced from the inherited 500 (font-medium) to
     400, plus 0.02em letter-spacing. Subtle but lifts the labels from utility
     sans to editorial typesetting — the same restraint that distinguishes a
     printed-page editorial from a UI feature-bar. */
  .desktop-nav-link {
    position: relative;
    display: inline-block;
    padding-bottom: 0.45rem;
    color: var(--atelier-stone-600);
    font-weight: 400;
    letter-spacing: 0.02em;
    transition: color 200ms ease;
  }
  .desktop-nav-link:hover,
  .desktop-nav-link.is-active {
    color: var(--atelier-stone-900);
  }
  .desktop-nav-link::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 0;
    transform: translateX(-50%);
    width: 0;
    height: 1.5px;
    background: var(--atelier-brass-600);
    transition: width 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .desktop-nav-link:hover::after,
  .desktop-nav-link:focus-visible::after,
  .desktop-nav-link.is-active::after {
    width: 70%;
  }

  /* Open Studio CTA — refined hover state. At rest the button carries a
     standard dark shadow (the anchor of the bar). On hover, a brass-tinted
     glow layers over the dark base, surfacing the brand accent on intent
     without changing the button's ink colour. The dark fill stays the bar's
     stopping point; brass arrives only as the visitor commits. */
  .studio-cta {
    box-shadow: 0 6px 18px -6px rgba(28, 25, 23, 0.22);
    transition: box-shadow 320ms cubic-bezier(0.22, 1, 0.36, 1), background-color 200ms ease, transform 100ms ease;
  }
  .studio-cta:hover {
    box-shadow:
      0 10px 28px -8px rgba(212, 179, 120, 0.4),
      0 6px 18px -6px rgba(28, 25, 23, 0.18);
  }

  /* Mobile menu overlay — fades in/out, locked invisible until [data-open=true] */
  #mobile-menu {
    visibility: hidden;
    opacity: 0;
    transition: opacity 300ms ease, visibility 0s 300ms;
  }
  #mobile-menu[data-open="true"] {
    visibility: visible;
    opacity: 1;
    transition: opacity 300ms ease;
  }

  /* Nav links inside the overlay — clean display-serif text, no bullet
     ornament. A brass hairline draws beneath each link on hover, from
     centre outward (same micro-interaction as the Return-to-top link
     in the footer — keeps the site's hover vocabulary consistent).
     Links tween in from the right with cascading delays (set per-link
     inline via animation-delay). */
  .mobile-nav-link {
    position: relative;
    display: inline-block;
    padding-bottom: 0.4rem;
    opacity: 0;
    transform: translateX(0.75rem);
  }
  #mobile-menu[data-open="true"] .mobile-nav-link {
    animation: mobile-nav-link-in 450ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .mobile-nav-link::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 0;
    transform: translateX(-50%);
    width: 0;
    height: 1.5px;
    background: var(--atelier-brass-600);
    transition: width 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .mobile-nav-link:hover::after,
  .mobile-nav-link:focus-visible::after {
    width: 80%;
  }

  @keyframes mobile-nav-link-in {
    from { opacity: 0; transform: translateX(0.75rem); }
    to   { opacity: 1; transform: translateX(0); }
  }
</style>

<script>
  /* Mobile menu open/close. Vanilla JS — no React needed for a toggle.
     Handles: trigger click, close button click, ESC key, body scroll lock,
     aria-expanded attr, and auto-close on link click (so navigating away
     doesn't leave a stale overlay state if the browser caches the page). */
  const menu = document.getElementById('mobile-menu');
  const trigger = document.getElementById('mobile-menu-trigger');
  const closeBtn = document.getElementById('mobile-menu-close');

  function openMenu() {
    if (!menu || !trigger) return;
    menu.dataset.open = 'true';
    menu.setAttribute('aria-hidden', 'false');
    trigger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    if (!menu || !trigger) return;
    menu.dataset.open = 'false';
    menu.setAttribute('aria-hidden', 'true');
    trigger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  trigger?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);

  /* ESC closes the menu when open */
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu?.dataset.open === 'true') closeMenu();
  });

  /* Any link tap inside the menu closes it. Navigation usually unmounts the
     page anyway, but if the destination is cached (bfcache) the overlay
     would otherwise come back open on Back. */
  document.querySelectorAll('[data-mobile-link]').forEach((el) => {
    el.addEventListener('click', closeMenu);
  });

  /* Restore body scroll if the page is restored from bfcache mid-open */
  window.addEventListener('pageshow', () => {
    if (menu?.dataset.open !== 'true') document.body.style.overflow = '';
  });
</script>
