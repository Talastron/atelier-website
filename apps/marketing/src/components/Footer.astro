---
// apps/marketing/src/components/Footer.astro
//
// The closing chapter. Treated as the back cover of a book.
//
// Two distinct treatments — mobile and desktop are different compositions,
// not the same composition resized:
//
//   MOBILE (default → lg)
//     Vertical centered stack — like a publisher's frontispiece:
//       1. Brand mast — hanger atop the wordmark (vertical, not horizontal)
//       2. Single-line tagline
//       3. Brass-rule Volume I · MMXXVI eyebrow
//       4. Three nav sections, stacked, generous editorial rhythm
//       5. Armoire centerpiece (larger than on desktop — full canvas)
//       6. Address line beneath
//       7. Brass-rule divider
//       8. Colophon — stacked centered
//       9. Return to the top — graceful exit link
//
//   DESKTOP (lg+)
//     12-column grid — brand : nav : signature read left to right:
//       3 cols brand | 6 cols nav (3 sub-cols) | 3 cols signature
//
// The signature artifact (armoire) is a Regency-style line drawing. The
// SVG below is a tasteful placeholder; replacement with a commissioned
// illustrator drawing should swap only the <svg> markup, leaving the
// layout, address line, and surrounding chrome intact.
//
// Address line ("The Long Barn · Cobham · Surrey") uses Atelier's real
// registered office in frontispiece form. The full statutory address
// (with postcode + Companies Act disclosures) lives quietly in the
// colophon below.
import { AtelierMark } from '@atelier/ui';
import { EDIT_URL, SITE } from '../config.ts';
import { ArrowUp } from 'lucide-react';
import NewsletterSignup from './NewsletterSignup.astro';

// Convert the current year to Roman numerals so the copyright line reads
// in the same vocabulary as the rest of the site (MMXXVI in the nav kicker,
// closing mastheads, the Footer's own 'Volume I · MMXXVI' eyebrow). Dynamic
// rather than hardcoded so it auto-updates on January 1st.
function toRoman(num: number): string {
  const vals = [1000, 900, 500, 400, 100, 90, 50, 40, 10, 9, 5, 4, 1];
  const syms = ['M', 'CM', 'D', 'CD', 'C', 'XC', 'L', 'XL', 'X', 'IX', 'V', 'IV', 'I'];
  let n = num;
  let out = '';
  for (let i = 0; i < vals.length; i += 1) {
    while (n >= vals[i]) {
      out += syms[i];
      n -= vals[i];
    }
  }
  return out;
}

const year = toRoman(new Date().getFullYear());

const sections = [
  {
    eyebrow: 'The House',
    links: [
      { label: 'About', href: '/about' },
      { label: 'Journal', href: '/journal' },
      { label: 'Pricing', href: '/pricing' },
    ],
  },
  {
    eyebrow: 'The Studio',
    links: [
      { label: 'Sign In', href: EDIT_URL },
      { label: 'Open Studio', href: EDIT_URL },
      { label: 'Manage subscription', href: 'https://myatelier.lemonsqueezy.com/billing', external: true },
    ],
  },
  {
    eyebrow: 'Support',
    links: [
      { label: SITE.supportEmail, href: `mailto:${SITE.supportEmail}` },
      { label: 'Privacy', href: '/legal/privacy/' },
      { label: 'Terms', href: '/legal/terms/' },
    ],
  },
];

// Atelier hanger mark inlined here so the armoire SVG below can reuse
// the same brass + stone vocabulary. Kept in this file because the
// footer is the only consumer of the larger 56px size.
---

<footer
  id="footer"
  class="border-t border-stone-200/60"
  style="background: var(--atelier-cream);"
>
  <div
    class="mx-auto"
    style="max-width: var(--atelier-container-max); padding-inline: var(--atelier-page-padding);"
  >
    {/* ──────────────────────────────────────────────────────────────────
        MOVEMENT 1: Masthead + Navigation + Signature
        Mobile: stacked vertical, centered. Desktop: 12-col grid.
        ────────────────────────────────────────────────────────────── */}
    <div
      class="flex flex-col items-center text-center gap-y-14 md:gap-y-16 lg:grid lg:grid-cols-12 lg:items-start lg:text-left lg:gap-y-0 lg:gap-x-12"
      style="padding-top: clamp(4.5rem, 8vw, 6.5rem); padding-bottom: clamp(3rem, 5vw, 4rem);"
    >
      {/* ── Brand mast (mobile: vertical centered · desktop: left col) ── */}
      <div class="lg:col-span-3 flex flex-col items-center lg:items-start" style="max-width: 32ch;">
        {/* Brand mark — vertical on mobile (mast over wordmark), horizontal
            on desktop. The mobile vertical treatment reads as a book
            frontispiece — more iconic, more present. */}
        <a
          href="/"
          class="flex flex-col items-center lg:flex-row lg:items-center gap-3 group"
          aria-label="Atelier — return home"
        >
          {/* Two AtelierMark instances — one mobile (64px, large
              centerpiece mast), one desktop (44px, sidebar scale). The
              AtelierMark component renders width/height from its size
              prop, so this is cheaper than CSS-resizing the SVG. */}
          <div class="lg:hidden">
            <AtelierMark size={64} client:load />
          </div>
          <div class="hidden lg:block">
            <AtelierMark size={44} client:load />
          </div>
          <span
            class="tracking-tight transition-colors group-hover:text-stone-700 text-[2.25rem] lg:text-[1.625rem]"
            style="font-family: var(--atelier-font-display); color: var(--atelier-stone-900); letter-spacing: -0.005em; line-height: 1;"
          >
            Atelier<span style="color: var(--atelier-brass-600);">.</span>
          </span>
        </a>

        {/* Tagline — single declarative line */}
        <p
          class="mt-6 lg:mt-5"
          style="color: var(--atelier-stone-500); font-size: 0.9375rem; line-height: 1.6;"
        >
          Quiet luxury for your wardrobe.
        </p>

        {/* Volume eyebrow — brass rule + edition */}
        <div class="flex items-center gap-3 mt-8 lg:mt-7">
          <span
            aria-hidden="true"
            style="display: inline-block; width: 24px; height: 1.5px; background: var(--atelier-brass-300);"
          />
          <p
            class="text-[10px] uppercase font-medium"
            style="letter-spacing: 0.32em; color: var(--atelier-stone-500);"
          >
            Volume I &middot; MMXXVI
          </p>
          <span
            class="lg:hidden"
            aria-hidden="true"
            style="display: inline-block; width: 24px; height: 1.5px; background: var(--atelier-brass-300);"
          />
        </div>
      </div>

      {/* ── Navigation ───────────────────────────────────────────────────
          Mobile: vertical stack of sections, generous editorial rhythm.
          Desktop (md+): 3-column grid. Skip the cramped 640px-tablet
          3-col state — go straight from stacked → proper grid at md. */}
      <nav
        class="lg:col-span-6 w-full flex flex-col items-center lg:items-stretch md:grid md:grid-cols-3 lg:gap-x-12 md:text-left"
        style="gap: clamp(2.5rem, 4vw, 2.5rem);"
        aria-label="Footer navigation"
      >
        {sections.map((section) => (
          <div class="flex flex-col items-center md:items-start">
            <h3
              class="mb-5 text-[10px] uppercase font-semibold"
              style="letter-spacing: 0.28em; color: var(--atelier-stone-900);"
            >
              {section.eyebrow}
            </h3>
            <ul class="flex flex-col gap-1">
              {section.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                    class="footer-link text-sm inline-block"
                    style="line-height: 1.5; padding-block: 0.5rem;"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>

      {/* ── Signature artifact ──────────────────────────────────────────
          Mobile: centered centerpiece, larger (~184px). Desktop: right
          column, smaller (148px). The mobile treatment makes this the
          unmissable closing moment of the page. */}
      <div
        class="lg:col-span-3 flex flex-col items-center lg:items-end gap-5 lg:gap-4"
      >
        {/* Armoire SVG. Width is responsive: larger on mobile where it
            has the full canvas, smaller on desktop where it sits in
            a 3-col sidebar. Aspect ratio preserved by viewBox. */}
        <svg
          viewBox="0 0 160 280"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          class="footer-armoire"
          style="display: block;"
        >
          {/* ── Pediment: urn finial + swan-neck scrolls ──────────── */}
          <g stroke="var(--atelier-stone-700)" stroke-width="0.7" fill="none" stroke-linecap="round">
            <path d="M 77 4 Q 80 1 83 4" />
            <line x1="80" y1="4" x2="80" y2="8" />
            <ellipse cx="80" cy="11" rx="3.5" ry="2" />
            <path d="M 76.5 12 Q 80 22 83.5 12" />
            <line x1="76" y1="22" x2="84" y2="22" />
          </g>

          <path d="M 16 36 Q 18 24 38 22 Q 60 20 76 22" fill="none" stroke="var(--atelier-stone-700)" stroke-width="1.1" stroke-linecap="round" />
          <path d="M 144 36 Q 142 24 122 22 Q 100 20 84 22" fill="none" stroke="var(--atelier-stone-700)" stroke-width="1.1" stroke-linecap="round" />
          <path d="M 22 36 Q 24 28 40 26 Q 60 24 76 26" fill="none" stroke="var(--atelier-stone-400)" stroke-width="0.6" stroke-linecap="round" />
          <path d="M 138 36 Q 136 28 120 26 Q 100 24 84 26" fill="none" stroke="var(--atelier-stone-400)" stroke-width="0.6" stroke-linecap="round" />

          {/* ── Cornice + dentil moulding ──────────────────────────── */}
          <line x1="14" y1="38" x2="146" y2="38" stroke="var(--atelier-stone-700)" stroke-width="1.1" stroke-linecap="round" />
          <line x1="16" y1="41" x2="144" y2="41" stroke="var(--atelier-stone-500)" stroke-width="0.7" />
          <line x1="14" y1="46" x2="146" y2="46" stroke="var(--atelier-stone-700)" stroke-width="0.9" />

          <g fill="var(--atelier-stone-600)">
            <rect x="22" y="48" width="4" height="3" />
            <rect x="34" y="48" width="4" height="3" />
            <rect x="46" y="48" width="4" height="3" />
            <rect x="58" y="48" width="4" height="3" />
            <rect x="70" y="48" width="4" height="3" />
            <rect x="86" y="48" width="4" height="3" />
            <rect x="98" y="48" width="4" height="3" />
            <rect x="110" y="48" width="4" height="3" />
            <rect x="122" y="48" width="4" height="3" />
            <rect x="134" y="48" width="4" height="3" />
          </g>
          <line x1="14" y1="54" x2="146" y2="54" stroke="var(--atelier-stone-700)" stroke-width="1.1" stroke-linecap="round" />

          {/* ── Body ──────────────────────────────────────────────── */}
          <rect x="18" y="54" width="124" height="178" fill="none" stroke="var(--atelier-stone-700)" stroke-width="1.2" />
          <line x1="80" y1="58" x2="80" y2="228" stroke="var(--atelier-stone-700)" stroke-width="1" />

          {/* ── Left door — closed, with cartouche panel + brass ──── */}
          <rect x="22" y="58" width="55" height="170" fill="none" stroke="var(--atelier-stone-600)" stroke-width="0.7" />
          <rect x="28" y="64" width="43" height="62" fill="none" stroke="var(--atelier-stone-600)" stroke-width="0.9" />
          <rect x="31" y="67" width="37" height="56" fill="none" stroke="var(--atelier-stone-400)" stroke-width="0.5" />
          <ellipse cx="49.5" cy="95" rx="9" ry="13" fill="none" stroke="var(--atelier-stone-500)" stroke-width="0.6" />
          <ellipse cx="49.5" cy="95" rx="6.5" ry="10" fill="none" stroke="var(--atelier-stone-400)" stroke-width="0.4" />
          <rect x="28" y="138" width="43" height="84" fill="none" stroke="var(--atelier-stone-600)" stroke-width="0.9" />
          <rect x="31" y="141" width="37" height="78" fill="none" stroke="var(--atelier-stone-400)" stroke-width="0.5" />
          <g>
            <ellipse cx="72" cy="132" rx="2.5" ry="3.2" fill="var(--atelier-cream)" stroke="var(--atelier-brass-600)" stroke-width="0.5" />
            <line x1="72" y1="131" x2="72" y2="133.5" stroke="var(--atelier-brass-600)" stroke-width="0.5" stroke-linecap="round" />
            <circle cx="72" cy="138" r="2.2" fill="none" stroke="var(--atelier-brass-600)" stroke-width="0.55" />
          </g>

          {/* ── Right door — mirror of left ─────────────────────────── */}
          <rect x="83" y="58" width="55" height="170" fill="none" stroke="var(--atelier-stone-600)" stroke-width="0.7" />
          <rect x="89" y="64" width="43" height="62" fill="none" stroke="var(--atelier-stone-600)" stroke-width="0.9" />
          <rect x="92" y="67" width="37" height="56" fill="none" stroke="var(--atelier-stone-400)" stroke-width="0.5" />
          <ellipse cx="110.5" cy="95" rx="9" ry="13" fill="none" stroke="var(--atelier-stone-500)" stroke-width="0.6" />
          <ellipse cx="110.5" cy="95" rx="6.5" ry="10" fill="none" stroke="var(--atelier-stone-400)" stroke-width="0.4" />
          <rect x="89" y="138" width="43" height="84" fill="none" stroke="var(--atelier-stone-600)" stroke-width="0.9" />
          <rect x="92" y="141" width="37" height="78" fill="none" stroke="var(--atelier-stone-400)" stroke-width="0.5" />
          <g>
            <ellipse cx="88" cy="132" rx="2.5" ry="3.2" fill="var(--atelier-cream)" stroke="var(--atelier-brass-600)" stroke-width="0.5" />
            <line x1="88" y1="131" x2="88" y2="133.5" stroke="var(--atelier-brass-600)" stroke-width="0.5" stroke-linecap="round" />
            <circle cx="88" cy="138" r="2.2" fill="none" stroke="var(--atelier-brass-600)" stroke-width="0.55" />
          </g>

          {/* ── Apron + plinth + bracket feet ──────────────────────── */}
          <line x1="14" y1="232" x2="146" y2="232" stroke="var(--atelier-stone-700)" stroke-width="1.1" stroke-linecap="round" />
          <line x1="16" y1="236" x2="144" y2="236" stroke="var(--atelier-stone-500)" stroke-width="0.6" />
          <path d="M 16 240 L 60 240 Q 80 250 100 240 L 144 240" fill="none" stroke="var(--atelier-stone-700)" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M 16 240 L 14 258 L 22 258 L 24 240" fill="none" stroke="var(--atelier-stone-700)" stroke-width="0.9" stroke-linejoin="round" />
          <path d="M 136 240 L 138 258 L 146 258 L 144 240" fill="none" stroke="var(--atelier-stone-700)" stroke-width="0.9" stroke-linejoin="round" />

          {/* ── Floor shadow ──────────────────────────────────────── */}
          <line x1="6" y1="264" x2="154" y2="264" stroke="var(--atelier-stone-300)" stroke-width="0.6" stroke-linecap="round" />
        </svg>

        {/* Address line — frontispiece form. Three units of increasing
            geography. Real registered office, not invented. */}
        <div class="flex flex-col items-center lg:items-end gap-2.5">
          <span
            aria-hidden="true"
            style="display: inline-block; width: 18px; height: 1.5px; background: var(--atelier-brass-300);"
          />
          <p
            class="text-[10px] uppercase font-medium text-center lg:text-right"
            style="letter-spacing: 0.32em; color: var(--atelier-stone-700); line-height: 1.9;"
          >
            The Long Barn<br />
            Cobham<br />
            Surrey
          </p>
        </div>
      </div>
    </div>

    <div style="margin: 2rem 0; max-width: 24rem;">
      <NewsletterSignup variant="compact" source="footer" />
    </div>

    {/* ── Brass-rule divider ──────────────────────────────────────── */}
    <div
      aria-hidden="true"
      style="height: 1px; background: linear-gradient(to right, transparent, var(--atelier-stone-200) 15%, var(--atelier-stone-200) 85%, transparent);"
    />

    {/* ──────────────────────────────────────────────────────────────────
        MOVEMENT 2: Colophon
        Mobile: stacked, centered, generous gap. Desktop: flex-row.
        ────────────────────────────────────────────────────────────── */}
    <div
      class="flex flex-col items-center text-center md:flex-row md:items-baseline md:justify-between md:text-left gap-6 md:gap-4"
      style="padding-top: 2.5rem; padding-bottom: 2rem;"
    >
      {/* Copyright + brand attribution */}
      <p
        class="text-[11px] uppercase"
        style="letter-spacing: 0.22em; color: var(--atelier-stone-500); font-weight: 500;"
      >
        &copy; {year} Atelier &middot; A product of Talastron Ltd
      </p>

      {/* Statutory disclosure — structured as discrete lines on mobile
          so middle-dot separators don't break mid-line, and the eye
          can rest at each fact. Recombines into two lines on desktop. */}
      <div
        class="flex flex-col gap-0.5 md:text-right"
        style="color: var(--atelier-stone-400); font-size: 11px; line-height: 1.7; max-width: 60ch;"
      >
        <p class="hidden md:block">
          Talastron Ltd &middot; Registered in England &amp; Wales &middot; Company No. 15464691 &middot; VAT No. GB&nbsp;463&nbsp;5874&nbsp;58
        </p>
        <p class="md:hidden">Talastron Ltd</p>
        <p class="md:hidden">Registered in England &amp; Wales</p>
        <p class="md:hidden">Company No. 15464691 &middot; VAT No. GB&nbsp;463&nbsp;5874&nbsp;58</p>
        <p>
          Registered office: The Long Barn, Cobham Park Road,<br class="hidden md:block" />
          Cobham, Surrey, KT11&nbsp;3NE
        </p>
      </div>
    </div>

    {/* ──────────────────────────────────────────────────────────────────
        Closing flourish — literary endline, then graceful exit.
        Three centered brass dots act as a typographic transition mark
        (the way fine printing uses an asterism ⁂ to separate sections),
        then a one-line italic colophon — the equivalent of "Composed in
        Garamond" at the back of a book, but earned for Atelier — and
        finally the Return-to-top link as the polite way out.
        ────────────────────────────────────────────────────────────── */}
    <div
      class="flex flex-col items-center"
      style="padding-top: 2rem; padding-bottom: clamp(2.5rem, 5vw, 3rem); gap: 1.5rem;"
    >
      {/* Three brass dots — the asterism */}
      <div class="flex items-center gap-2" aria-hidden="true">
        <span style="display: inline-block; width: 3px; height: 3px; border-radius: 50%; background: var(--atelier-brass-300);" />
        <span style="display: inline-block; width: 3px; height: 3px; border-radius: 50%; background: var(--atelier-brass-600);" />
        <span style="display: inline-block; width: 3px; height: 3px; border-radius: 50%; background: var(--atelier-brass-300);" />
      </div>

      {/* Literary closing line — italic display serif */}
      <p
        class="text-center italic"
        style="font-family: var(--atelier-font-display); color: var(--atelier-stone-500); font-size: 13px; line-height: 1.6; max-width: 42ch;"
      >
        Composed in Surrey, for considered closets everywhere.
      </p>

      {/* Return to the top — brass underline draws on hover */}
      <a
        href="#top"
        class="footer-return inline-flex items-center gap-2 text-[10px] uppercase font-medium"
        style="letter-spacing: 0.32em; color: var(--atelier-stone-400); padding: 0.75rem 1rem;"
      >
        Return to the top
        <ArrowUp size={11} strokeWidth={1.6} client:load />
      </a>
    </div>
  </div>
</footer>

<style>
  /* Footer nav links — CSS hover/focus replaces inline JS for
     keyboard accessibility and reduced-motion support. */
  .footer-link {
    color: var(--atelier-stone-600);
    transition: color 200ms ease;
  }
  .footer-link:hover,
  .footer-link:focus-visible {
    color: var(--atelier-stone-900);
  }

  /* Return-to-top link — brass underline draws on hover, from the
     centre outward. Subtle but tells the visitor someone designed it.
     The underline sits just below the text, brass-600, 1px high. */
  .footer-return {
    position: relative;
    transition: color 250ms ease;
  }
  .footer-return::after {
    content: '';
    position: absolute;
    bottom: 0.45rem;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 1px;
    background: var(--atelier-brass-600);
    transition: width 300ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .footer-return:hover,
  .footer-return:focus-visible {
    color: var(--atelier-stone-900);
  }
  .footer-return:hover::after,
  .footer-return:focus-visible::after {
    width: calc(100% - 2rem);
  }

  /* Armoire SVG — responsive width via clamp(); height auto from
     viewBox aspect ratio. On mobile, scales between 160px (iPhone SE
     comfort) and 184px (large phones / small tablets) by viewport
     proportion. Desktop overrides to 148px in the sidebar position. */
  .footer-armoire {
    width: clamp(160px, 46vw, 184px);
    height: auto;
  }
  @media (min-width: 1024px) {
    .footer-armoire {
      width: 148px;
    }
  }
</style>
