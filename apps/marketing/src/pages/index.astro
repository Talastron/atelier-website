---
// apps/marketing/src/pages/index.astro
// Each landing section sized to fit a single viewport without scrolling.
// Hero + auto-shuffling outfit row, then Concierge spotlight (top-aligned
// copy + demo), then Suggest-a-Look spotlight (centered, tight copy).

import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Philosophy from '../components/Philosophy.astro';
import ClosingMasthead from '../components/ClosingMasthead.astro';
import { Hero } from '../components/landing/Hero.jsx';
import { ConciergeDemo } from '../components/landing/ConciergeDemo.jsx';
import { SuggestALookDemo } from '../components/landing/SuggestALookDemo.jsx';
import { InvestmentLens } from '../components/landing/InvestmentLens.jsx';
import { TravelCapsuleDemo } from '../components/landing/TravelCapsuleDemo.jsx';
import JournalRail from '../components/JournalRail.astro';
import { BrassRule } from '@atelier/ui';
import { SITE, EDIT_URL } from '../config.ts';

// SoftwareApplication structured data — tells Google this page represents
// a piece of software, which unlocks rich snippets (ratings, price, screen-
// shots) when the brand is searched for. We declare the founding-member
// price (£79/yr) here as the lower of the two tiers; the public price is
// surfaced on /pricing where a more detailed Product schema would belong.
const softwareLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: SITE.name,
  url: SITE.url,
  applicationCategory: 'LifestyleApplication',
  operatingSystem: 'Web',
  description: 'A private digital wardrobe and AI stylist. Capture your pieces, log wears, and have an AI compose outfits from what you already own.',
  offers: {
    '@type': 'Offer',
    price: '79',
    priceCurrency: 'GBP',
    url: `${SITE.url}/pricing`,
    availability: 'https://schema.org/InStock',
  },
};
---

<Base
  title="Atelier — An AI stylist that knows your wardrobe"
  jsonLd={softwareLd}
>
  <Nav />
  <main>
    {/* ── Hero ──────────────────────────────────────────────────────── */}
    <Hero client:load />

    {/* ── What Atelier does — states the app's purpose plainly (header →
        four-capability grid: Catalogue / Log / Style / Track) for the Google
        OAuth homepage review, in the site's own editorial design language. ── */}
    <section
      id="what-atelier-does"
      style="background: var(--atelier-cream); padding-block: clamp(4rem, 8vw, 7rem); padding-inline: var(--atelier-page-padding); border-top: 1px solid rgba(212, 179, 120, 0.18);"
    >
      <div class="mx-auto" style="max-width: 1180px;">
        {/* Header */}
        <div style="max-width: 640px;">
          <div class="flex items-center gap-3 mb-5">
            <BrassRule client:load />
            <p class="text-[10px] uppercase font-medium" style="letter-spacing: 0.28em; color: var(--atelier-brass-600);">
              What Atelier does
            </p>
          </div>
          <h2
            style="font-family: var(--atelier-font-display); font-size: clamp(2rem, 3.6vw, 3.25rem); line-height: 1.05; letter-spacing: -0.01em; color: var(--atelier-stone-900); margin-bottom: 1.5rem;"
          >
            A digital wardrobe, <em style="font-weight: 400;">and a stylist</em> who's read every piece.
          </h2>
          <p style="font-size: clamp(1rem, 1.15vw, 1.125rem); line-height: 1.7; color: var(--atelier-stone-600); max-width: 56ch;">
            Atelier is a personal styling app. You catalogue the clothes you already own, log what
            you wear, and an AI stylist — the Concierge — composes head-to-toe outfits from
            <em>your own</em> wardrobe.
          </p>
        </div>

        {/* Capabilities — four plain statements of what the app does */}
        <div
          style="display: grid; grid-template-columns: repeat(auto-fit, minmax(218px, 1fr)); gap: clamp(2rem, 3vw, 3.5rem); margin-top: clamp(2.75rem, 5vw, 4.5rem); padding-top: clamp(2.5rem, 4vw, 3.5rem); border-top: 1px solid rgba(28, 25, 23, 0.08);"
        >
          {[
            { t: 'Catalogue', d: 'Photograph or import every piece you own. Atelier builds your private digital wardrobe.' },
            { t: 'Log', d: 'Record what you actually wear, so the Concierge styles you from your real habits.' },
            { t: 'Style', d: 'The AI composes outfits from your own clothes, plans your week, and packs your trips.' },
            { t: 'Track', d: 'See the cost-per-wear of every piece — and where your wardrobe has gaps.' },
          ].map((c) => (
            <div>
              <span style="display: block; width: 26px; height: 1.5px; background: var(--atelier-brass-300); margin-bottom: 1.1rem;" aria-hidden="true"></span>
              <h3 style="font-family: var(--atelier-font-display); font-size: 1.3125rem; line-height: 1.1; color: var(--atelier-stone-900); margin-bottom: 0.6rem;">{c.t}</h3>
              <p style="font-size: 0.9375rem; line-height: 1.6; color: var(--atelier-stone-600);">{c.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── Section 2: Meet the Concierge ─────────────────────────────── */}
    <section
      style="background: var(--atelier-stone-50); min-height: 100vh; display: flex; align-items: center; padding-block: clamp(3rem, 6vw, 5rem); padding-inline: var(--atelier-page-padding);"
    >
      {/* Container narrowed from 1280px to 1180px to give the left column
          more visual inset; gap widened so the copy block and the demo each
          get their own room rather than reading as one wide composition. */}
      <div
        class="mx-auto grid lg:grid-cols-[5fr_7fr] gap-10 lg:gap-20 items-start w-full"
        style="max-width: 1180px;"
      >
        {/* Copy column — top-aligned with the demo */}
        <div class="text-left lg:pt-2">
          <div class="flex items-center gap-3 mb-5">
            <BrassRule client:load />
            <p
              class="text-[10px] uppercase font-medium"
              style="letter-spacing: 0.28em; color: var(--atelier-brass-600);"
            >
              Meet The Concierge
            </p>
          </div>
          <h2
            class="mb-5"
            style="font-family: var(--atelier-font-display); font-size: clamp(2rem, 3.5vw, 3.25rem); line-height: 1.05; color: var(--atelier-stone-900); letter-spacing: -0.01em; max-width: 18ch;"
          >
            A <em style="font-weight: 400;">private stylist</em> on call.
          </h2>
          <p
            class="mb-9"
            style="font-size: clamp(0.95rem, 1.1vw, 1.0625rem); line-height: 1.6; color: var(--atelier-stone-600); max-width: 48ch;"
          >
            The Concierge has read every piece in your wardrobe, every wear you've logged, every
            look you've saved. Ask it what to wear, what's missing, what to pack. It answers from
            <em>your</em> closet.
          </p>

          {/* Three editorial movements. Roman numerals in brass Playfair italic
              match the Journal essay numbering pattern; brass-rule + uppercase
              verb-eyebrow + descriptive line replaces the powerpoint bullets
              with a magazine-spread treatment. */}
          <ol class="flex flex-col gap-7" style="max-width: 46ch; list-style: none; padding: 0;">
            {[
              {
                roman: 'I',
                verb: 'Reads every piece',
                text: 'Every garment you own, every wear you have logged, every look you have saved.',
              },
              {
                roman: 'II',
                verb: 'Sees the day',
                text: 'The forecast, your Google Calendar — read-only, never edited or shared — and what is and is not in the wash.',
              },
              {
                roman: 'III',
                verb: 'Writes in your voice',
                text: 'Briefs in your own taste, not generic suggestions.',
              },
            ].map((m) => (
              <li class="grid" style="grid-template-columns: 2.25rem 1fr; gap: 1rem;">
                <span
                  style="font-family: var(--atelier-font-display); font-style: italic; font-size: 1.5rem; color: var(--atelier-brass-600); line-height: 1; padding-top: 0.125rem; font-feature-settings: 'onum' on;"
                >
                  {m.roman}
                </span>
                <div>
                  <div class="flex items-center gap-3 mb-1.5">
                    <span
                      aria-hidden="true"
                      style="display: inline-block; width: 18px; height: 1.5px; background: var(--atelier-brass-300); flex-shrink: 0;"
                    />
                    <p
                      class="text-[10px] uppercase font-semibold"
                      style="letter-spacing: 0.22em; color: var(--atelier-stone-900);"
                    >
                      {m.verb}
                    </p>
                  </div>
                  <p
                    style="font-size: 0.9375rem; line-height: 1.55; color: var(--atelier-stone-600);"
                  >
                    {m.text}
                  </p>
                </div>
              </li>
            ))}
          </ol>
        </div>

        {/* Live auto-play demo */}
        <div class="flex justify-center lg:justify-end">
          <ConciergeDemo client:visible />
        </div>
      </div>
    </section>

    {/* ── Section 3: Suggest a Look (modal demo) ────────────────────── */}
    <section
      style="background: var(--atelier-cream); min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding-block: clamp(2.5rem, 5vw, 4rem); padding-inline: var(--atelier-page-padding);"
    >
      <div
        class="mx-auto w-full"
        style="max-width: var(--atelier-container-max);"
      >
        {/* Header — tightened to fit on one screen with the demo */}
        <div class="text-center mb-8">
          <div class="flex items-center justify-center gap-3 mb-4">
            <BrassRule client:load />
            <p
              class="text-[10px] uppercase font-medium"
              style="letter-spacing: 0.28em; color: var(--atelier-brass-600);"
            >
              The Daily Brief
            </p>
            <BrassRule client:load />
          </div>
          <h2
            class="mx-auto mb-3"
            style="font-family: var(--atelier-font-display); font-size: clamp(1.75rem, 3vw, 2.75rem); line-height: 1.05; color: var(--atelier-stone-900); letter-spacing: -0.01em; max-width: 22ch;"
          >
            Tap once. <em style="font-weight: 400;">Get styled</em> for today.
          </h2>
          <p
            class="mx-auto"
            style="font-size: clamp(0.9rem, 1.1vw, 1rem); line-height: 1.6; color: var(--atelier-stone-500); max-width: 50ch;"
          >
            The Concierge composes a head-to-toe outfit from your wardrobe in seconds, with the
            stylist's reasoning attached.
          </p>
        </div>

        {/* Live auto-play modal demo */}
        <SuggestALookDemo client:visible />
      </div>
    </section>

    {/* ── Section 4: The Investment Lens — stats spread ─────────────── */}
    <InvestmentLens client:visible />

    {/* ── Section 5: Travel Capsule — auto-rotating destinations ────── */}
    <TravelCapsuleDemo client:visible />

    {/* ── Section 6: Journal rail — three latest essays ─────────────── */}
    <JournalRail />

    {/* ── Closing CTA ────────────────────────────────────────────────── */}
    <Philosophy />

    {/* Site-wide closing masthead — same brand imprint that closes
        /about, /pricing, and both journal pages. */}
    <ClosingMasthead />
  </main>
  <Footer />
</Base>
