---
// apps/marketing/src/pages/studio.astro
//
// Interactive app preview — the strongest "this is software" page on the
// site. Visitors can click through a faithful React reproduction of the
// actual studio (sidebar, views, demos), driving it themselves rather
// than watching auto-play.
//
// Reached from: the hero's "See the studio" secondary CTA, the main nav
// "Studio" link, and the home page Studio section.

import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { BrassRule } from '@atelier/ui';
import { DeviceFrame } from '../components/preview/DeviceFrame.jsx';
import { StudioFrame } from '../components/preview/StudioFrame.jsx';
import { ChevronRight } from 'lucide-react';
---

<Base title="The Studio — Atelier" description="Step inside the Atelier studio. The same interface you'll sign in to, running in your browser with sample data.">
  <Nav />
  <main style="padding-top: 9rem; padding-block-end: clamp(5rem, 8vw, 7rem); padding-inline: var(--atelier-page-padding);">

    {/* Page intro */}
    <div class="mx-auto text-center mb-12" style="max-width: 680px;">
      <div class="flex items-center justify-center gap-3 mb-5">
        <BrassRule client:load />
        <p class="text-[10px] uppercase font-medium" style="letter-spacing: 0.32em; color: var(--atelier-brass-600);">
          The Studio · By preview
        </p>
        <BrassRule client:load />
      </div>
      <h1
        class="text-4xl md:text-5xl mx-auto mb-5"
        style="font-family: var(--atelier-font-display); line-height: 1.05; color: var(--atelier-stone-900); max-width: 22ch; letter-spacing: -0.015em;"
      >
        <em style="font-weight: 400;">This</em> is what you sign in to.
      </h1>
      <p
        style="font-size: clamp(0.95rem, 1.1vw, 1.0625rem); color: var(--atelier-stone-500); line-height: 1.65; max-width: 54ch; margin-inline: auto;"
      >
        A faithful preview of the Atelier studio, running in your browser with
        sample data. Click anywhere in the sidebar to switch views. Click inside
        a view to drive the demo. Everything below the browser bar is real, just
        not yours yet.
      </p>
    </div>

    {/* The device frame containing the live, interactive app */}
    <div style="max-width: 1280px; margin-inline: auto;">
      <DeviceFrame url="edit.myatelier.style" client:load>
        <StudioFrame client:load />
      </DeviceFrame>
    </div>

    {/* Closing CTA — visitors who've just played with the preview are in
        the best frame of mind to subscribe. Lead them to the keys. */}
    <div class="mx-auto text-center mt-20" style="max-width: 560px;">
      <div class="flex items-center justify-center gap-3 mb-5">
        <BrassRule client:load />
        <p class="text-[10px] uppercase font-medium" style="letter-spacing: 0.32em; color: var(--atelier-brass-600);">
          When you are ready
        </p>
        <BrassRule client:load />
      </div>
      <h2
        class="mx-auto mb-5"
        style="font-family: var(--atelier-font-display); font-size: clamp(1.625rem, 2.5vw, 2.25rem); line-height: 1.1; letter-spacing: -0.01em; color: var(--atelier-stone-900); max-width: 22ch;"
      >
        The keys to your own studio.
      </h2>
      <p
        class="mb-7"
        style="font-size: 1rem; line-height: 1.65; color: var(--atelier-stone-500); max-width: 46ch; margin-inline: auto;"
      >
        Fourteen days to compose your wardrobe inside the studio you just played with.
      </p>
      <a
        href="/pricing"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-full text-base font-semibold transition-all hover:opacity-90 active:scale-[0.98]"
        style="background: var(--atelier-stone-900); color: #ffffff; letter-spacing: 0.04em; box-shadow: 0 12px 32px -10px rgba(28, 25, 23, 0.3);"
      >
        Find the keys
        <ChevronRight size={16} strokeWidth={1.75} client:load />
      </a>
    </div>

  </main>
  <Footer />
</Base>
