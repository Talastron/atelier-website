---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { BrassRule, RomanNumeral } from '@atelier/ui';
import { getCollection } from 'astro:content';

const all = (await getCollection('journal', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

// Hero: the most recent essay (if any), otherwise the most recent post.
// Editorial convention — the cover features the lead essay, not the foreword.
const heroIdx = all.findIndex((p) => p.data.kind === 'essay');
const hero = heroIdx >= 0 ? all[heroIdx] : all[0];
const rest = all.filter((_, i) => i !== (heroIdx >= 0 ? heroIdx : 0));

// Pre-compute per-kind numbering (oldest first within each kind),
// so the contents can show "ESSAY N°.II" and "NOTE N°.V" without recounting at render.
const essaysOldestFirst = [...all].filter((p) => p.data.kind === 'essay').reverse();
const notesOldestFirst = [...all].filter((p) => p.data.kind !== 'essay').reverse();
function kindNumber(post: typeof all[number]): number {
  const seq = post.data.kind === 'essay' ? essaysOldestFirst : notesOldestFirst;
  return seq.findIndex((p) => p.slug === post.slug) + 1;
}

function fmtLongDate(d: Date) {
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
function fmtShortDate(d: Date) {
  return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'long' });
}
---

<Base title="The Journal — Atelier" description="Essays and notes on style, stewardship, and the considered wardrobe.">
  <Nav />
  <main>

    {/* ── Masthead ─────────────────────────────────────────────────────────── */}
    <section
      class="text-center"
      style="padding-top: 9rem; padding-bottom: 4rem; padding-inline: var(--atelier-page-padding);"
    >
      <p
        class="text-[11px] mb-5"
        style="letter-spacing: var(--atelier-tracking-eyebrow); color: var(--atelier-brass-600); font-weight: 500;"
      >
        THE ATELIER QUARTERLY
      </p>
      <div class="flex items-center justify-center gap-4 mb-2">
        <BrassRule client:load />
        <span
          class="figures-oldstyle"
          style="font-family: var(--atelier-font-display); font-style: italic; font-size: 1.5rem; color: var(--atelier-stone-700);"
        >
          Volume I · MMXXVI
        </span>
        <BrassRule client:load />
      </div>
      <h1
        class="mt-6 text-5xl md:text-7xl mx-auto"
        style="font-family: var(--atelier-font-display); line-height: var(--atelier-leading-display); color: var(--atelier-stone-900); max-width: 20ch;"
      >
        <em style="font-weight: 400;">Essays</em> &amp; Notes <span style="display: inline-block;">on the considered wardrobe.</span>
      </h1>
    </section>

    {/* ── Hero entry — the lead essay (or most recent piece) ───────────────── */}
    <section
      class="mx-auto"
      style="max-width: var(--atelier-container-max); padding-inline: var(--atelier-page-padding); margin-bottom: 12rem;"
    >
      <a href={`/journal/${hero.slug}`} class="block group">
        <div
          class="grid md:grid-cols-12 gap-8 md:gap-14 items-start py-16 md:py-20"
          style="border-top: 1px solid var(--atelier-stone-200); border-bottom: 1px solid var(--atelier-stone-200);"
        >
          {/* Left meta column */}
          <div class="md:col-span-3 flex flex-col gap-3">
            <p
              class="text-[10px]"
              style="letter-spacing: var(--atelier-tracking-eyebrow); color: var(--atelier-brass-600); font-weight: 500;"
            >
              {hero.data.kind === 'essay' ? 'THE LEAD ESSAY' : 'THE LATEST'}
            </p>
            <p
              class="figures-oldstyle"
              style="font-family: var(--atelier-font-display); font-style: italic; color: var(--atelier-stone-500); font-size: 1.05rem;"
            >
              {fmtLongDate(hero.data.date)}
            </p>
            {hero.data.kicker && (
              <p
                class="mt-4 text-[10px]"
                style="letter-spacing: var(--atelier-tracking-eyebrow); color: var(--atelier-stone-500); font-weight: 500;"
              >
                {hero.data.kicker}
              </p>
            )}
            <span style="display: inline-block; width: var(--atelier-brass-rule-width); height: var(--atelier-brass-rule-height); background: var(--atelier-brass-300); margin-top: 0.5rem;"></span>
          </div>

          {/* Right title + standfirst */}
          <div class="md:col-span-9">
            <h2
              class="text-4xl md:text-6xl tracking-tight mb-6 transition-colors group-hover:text-stone-600"
              style="font-family: var(--atelier-font-display); line-height: var(--atelier-leading-display); color: var(--atelier-stone-900);"
            >
              {hero.data.title}
            </h2>
            <p
              class="text-lg md:text-xl"
              style="color: var(--atelier-stone-600); line-height: var(--atelier-leading-snug); max-width: 52ch;"
            >
              {hero.data.description}
            </p>
            <span
              class="inline-flex items-center gap-2 mt-12 text-xs"
              style="letter-spacing: var(--atelier-tracking-eyebrow); color: var(--atelier-stone-700); font-weight: 500;"
            >
              {hero.data.kind === 'essay' ? 'READ THE ESSAY' : 'READ THE NOTE'}
              <span
                class="transition-transform group-hover:translate-x-1"
                style="color: var(--atelier-brass-600); display: inline-block;"
              >→</span>
            </span>
          </div>
        </div>
      </a>
    </section>

    {/* ── Table of Contents ───────────────────────────────────────────────── */}
    <section
      class="mx-auto"
      style="max-width: var(--atelier-container-max); padding-inline: var(--atelier-page-padding); padding-bottom: 10rem;"
    >
      <div class="flex items-center justify-center gap-4 mb-24">
        <BrassRule client:load />
        <p
          class="text-[11px]"
          style="letter-spacing: var(--atelier-tracking-eyebrow); color: var(--atelier-stone-500); font-weight: 500;"
        >
          TABLE OF CONTENTS
        </p>
        <BrassRule client:load />
      </div>

      <ol
        class="grid md:grid-cols-2 gap-x-24 lg:gap-x-32 gap-y-32"
        style="max-width: 1120px; margin: 0 auto; list-style: none; padding: 0;"
      >
        {(() => {
          // Track the running index of "note-style" cards (col-span-1) so the
          // chess-board drape only applies to notes — essays break the rhythm
          // and reset the counter.
          let noteVisualIdx = 0;
          return rest.map((post) => {
            const isEssay = post.data.kind === 'essay';
            const n = kindNumber(post);
            if (isEssay) {
              noteVisualIdx = 0; // reset drape after a full-row break
              return (
                <li class="md:col-span-2">
                  <a href={`/journal/${post.slug}`} class="block group">
                    <div class="flex items-baseline gap-5 mb-7">
                      <p
                        class="text-[11px]"
                        style="letter-spacing: var(--atelier-tracking-eyebrow); color: var(--atelier-brass-600); font-weight: 500;"
                      >
                        ESSAY N°
                      </p>
                      <RomanNumeral n={n} client:load className="text-3xl md:text-4xl" />
                      <span
                        class="flex-1"
                        style="height: 1px; background: var(--atelier-brass-300); transform: translateY(-0.4rem);"
                      ></span>
                      <span
                        class="text-sm figures-oldstyle"
                        style="font-family: var(--atelier-font-display); font-style: italic; color: var(--atelier-stone-500);"
                      >
                        {fmtShortDate(post.data.date)}
                      </span>
                    </div>
                    {post.data.kicker && (
                      <p
                        class="text-[10px] mb-4"
                        style="letter-spacing: var(--atelier-tracking-eyebrow); color: var(--atelier-stone-500); font-weight: 500;"
                      >
                        {post.data.kicker}
                      </p>
                    )}
                    <h3
                      class="text-3xl md:text-5xl tracking-tight mb-6 transition-colors group-hover:text-stone-600"
                      style="font-family: var(--atelier-font-display); line-height: var(--atelier-leading-display); color: var(--atelier-stone-900); max-width: 22ch;"
                    >
                      {post.data.title}
                    </h3>
                    <p
                      class="text-base md:text-lg"
                      style="color: var(--atelier-stone-500); line-height: var(--atelier-leading-snug); max-width: 60ch;"
                    >
                      {post.data.description}
                    </p>
                  </a>
                </li>
              );
            }
            // Note card — half-width, asymmetric drape
            const isOffset = noteVisualIdx % 2 === 1;
            noteVisualIdx += 1;
            return (
              <li class={isOffset ? 'md:mt-28' : ''}>
                <a href={`/journal/${post.slug}`} class="block group">
                  <div class="flex items-baseline gap-4 mb-5">
                    <p
                      class="text-[10px]"
                      style="letter-spacing: var(--atelier-tracking-eyebrow); color: var(--atelier-stone-500); font-weight: 500;"
                    >
                      NOTE N°
                    </p>
                    <RomanNumeral n={n} client:load className="text-2xl md:text-3xl" />
                    <span
                      class="flex-1"
                      style="height: 1px; background: var(--atelier-stone-300); transform: translateY(-0.35rem);"
                    ></span>
                    <span
                      class="text-xs figures-oldstyle"
                      style="font-family: var(--atelier-font-display); font-style: italic; color: var(--atelier-stone-500);"
                    >
                      {fmtShortDate(post.data.date)}
                    </span>
                  </div>
                  <p
                    class="text-[10px] mb-3"
                    style="letter-spacing: var(--atelier-tracking-eyebrow); color: var(--atelier-brass-600); font-weight: 500; min-height: 1em;"
                  >
                    {post.data.kicker ?? ' '}
                  </p>
                  <h3
                    class="text-2xl md:text-3xl tracking-tight mb-4 transition-colors group-hover:text-stone-600"
                    style="font-family: var(--atelier-font-display); line-height: var(--atelier-leading-tight); color: var(--atelier-stone-900);"
                  >
                    {post.data.title}
                  </h3>
                  <p
                    class="text-base"
                    style="color: var(--atelier-stone-500); line-height: var(--atelier-leading-snug); max-width: 42ch;"
                  >
                    {post.data.description}
                  </p>
                </a>
              </li>
            );
          });
        })()}
      </ol>
    </section>

    {/* ── Colophon strip ──────────────────────────────────────────────────── */}
    <section
      class="text-center"
      style="padding-block: 5rem; border-top: 1px solid var(--atelier-stone-200);"
    >
      <div class="flex items-center justify-center gap-4">
        <BrassRule client:load />
        <p
          class="text-[10px] figures-oldstyle"
          style="letter-spacing: var(--atelier-tracking-eyebrow); color: var(--atelier-stone-500); font-weight: 500;"
        >
          END OF CONTENTS · VOLUME I
        </p>
        <BrassRule client:load />
      </div>
    </section>

  </main>
  <Footer />
</Base>
