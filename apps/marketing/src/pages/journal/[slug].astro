---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ClosingMasthead from '../../components/ClosingMasthead.astro';
import { BrassRule, Colophon } from '@atelier/ui';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const all = (await getCollection('journal', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime()
  );

  // Per-kind sequences, oldest first — so the inaugural piece in each kind is N°.I.
  const essaysOld = [...all].filter((p) => p.data.kind === 'essay').reverse();
  const notesOld = [...all].filter((p) => p.data.kind !== 'essay').reverse();

  return all.map((post, idx) => {
    const seq = post.data.kind === 'essay' ? essaysOld : notesOld;
    const kindNumber = seq.findIndex((p) => p.slug === post.slug) + 1;
    return {
      params: { slug: post.slug },
      props: {
        post,
        // In date-desc order: newer = idx-1, older = idx+1.
        // For reading flow we call the older one "previous" and the newer one "next".
        newer: idx > 0 ? all[idx - 1] : null,
        older: idx < all.length - 1 ? all[idx + 1] : null,
        kindNumber,
      },
    };
  });
}

const { post, newer, older, kindNumber } = Astro.props;
const { Content } = await post.render();

function fmtLongDate(d: Date) {
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}

const kindLabel = post.data.kind === 'essay' ? 'ESSAY' : 'NOTE';
const mastheadLabel = `THE JOURNAL · VOL I · ${kindLabel} N°${String(kindNumber).padStart(2, '0')}`;
---

<Base title={`${post.data.title} — The Journal — Atelier`} description={post.data.description}>
  <Nav />

  {/* ── Masthead micro-strip ───────────────────────────────────────────────── */}
  <div class="text-center" style="padding-top: 7.5rem; padding-bottom: 0.5rem;">
    <div class="flex items-center justify-center gap-4">
      <BrassRule client:load />
      <p
        class="text-[10px] figures-oldstyle"
        style="letter-spacing: var(--atelier-tracking-eyebrow); color: var(--atelier-brass-600); font-weight: 500;"
      >
        {mastheadLabel}
      </p>
      <BrassRule client:load />
    </div>
  </div>

  <article
    class="mx-auto"
    style="max-width: var(--atelier-prose-max); padding-top: 3.5rem; padding-block-end: var(--atelier-section-padding-y); padding-inline: var(--atelier-page-padding);"
  >
    {/* ── Header ──────────────────────────────────────────────────────────── */}
    <header class="text-center mb-14">
      {post.data.kicker && (
        <p
          class="text-[10px] mb-7"
          style="letter-spacing: var(--atelier-tracking-eyebrow); color: var(--atelier-stone-500); font-weight: 500;"
        >
          {post.data.kicker}
        </p>
      )}
      <h1
        class="text-4xl md:text-5xl tracking-tight mb-9"
        style="font-family: var(--atelier-font-display); line-height: var(--atelier-leading-display); color: var(--atelier-stone-900);"
      >
        {post.data.title}
      </h1>
      <div class="flex items-center justify-center gap-4">
        <BrassRule client:load />
        <time
          class="text-sm figures-oldstyle"
          style="font-family: var(--atelier-font-display); font-style: italic; color: var(--atelier-stone-500);"
        >
          {fmtLongDate(post.data.date)}
        </time>
        <BrassRule client:load />
      </div>
    </header>

    {/* ── Body ─────────────────────────────────────────────────────────────── */}
    <div class="prose-atelier">
      <Content />
    </div>

    {/* ── Closing ornament ─────────────────────────────────────────────────── */}
    <Colophon client:load />

    {/* ── Previous / Next navigator ────────────────────────────────────────── */}
    {(older || newer) && (
      <nav
        class="grid grid-cols-1 md:grid-cols-2 gap-10 mt-20 pt-12"
        style="border-top: 1px solid var(--atelier-stone-200);"
      >
        {older ? (
          <a href={`/journal/${older.slug}`} class="group">
            <p
              class="text-[10px] mb-3"
              style="letter-spacing: var(--atelier-tracking-eyebrow); color: var(--atelier-stone-500); font-weight: 500;"
            >
              <span style="color: var(--atelier-brass-600);">←</span> PREVIOUS {older.data.kind === 'essay' ? 'ESSAY' : 'NOTE'}
            </p>
            <p
              class="text-xl md:text-2xl tracking-tight transition-colors group-hover:text-stone-600"
              style="font-family: var(--atelier-font-display); color: var(--atelier-stone-900); line-height: var(--atelier-leading-tight);"
            >
              {older.data.title}
            </p>
          </a>
        ) : (
          <span aria-hidden="true"></span>
        )}
        {newer ? (
          <a href={`/journal/${newer.slug}`} class="group md:text-right">
            <p
              class="text-[10px] mb-3"
              style="letter-spacing: var(--atelier-tracking-eyebrow); color: var(--atelier-stone-500); font-weight: 500;"
            >
              NEXT {newer.data.kind === 'essay' ? 'ESSAY' : 'NOTE'} <span style="color: var(--atelier-brass-600);">→</span>
            </p>
            <p
              class="text-xl md:text-2xl tracking-tight transition-colors group-hover:text-stone-600"
              style="font-family: var(--atelier-font-display); color: var(--atelier-stone-900); line-height: var(--atelier-leading-tight);"
            >
              {newer.data.title}
            </p>
          </a>
        ) : (
          <span aria-hidden="true"></span>
        )}
      </nav>
    )}

    {/* ── Return to index ──────────────────────────────────────────────────── */}
    <div class="text-center mt-16">
      <a
        href="/journal"
        class="inline-flex items-center gap-2 text-xs transition-colors hover:text-stone-900"
        style="letter-spacing: var(--atelier-tracking-eyebrow); color: var(--atelier-stone-500); font-weight: 500;"
      >
        RETURN TO THE QUARTERLY
      </a>
    </div>
  </article>

  {/* Site-wide closing masthead — bookends the article with the same brand
      imprint that closes /about, /pricing, and the journal index. Sits
      below the in-article Colophon and the Return-to-Quarterly link. */}
  <ClosingMasthead />

  <Footer />
</Base>
