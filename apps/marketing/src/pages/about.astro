---
// apps/marketing/src/pages/about.astro
//
// The brand's trust statement. Where visitors decide whether to give
// Atelier their wardrobe. Treated as a magazine "About this publication"
// note rather than a tech-founder pitch.
//
// Structure (six movements):
//   1. Hero — editorial mast + manifesto headline + considered subhead
//   2. The Question — origin paragraph (why Atelier exists)
//   3. The Practice — what Atelier does day-to-day
//   4. A Style Manifesto — embedded sample. Showcases the AI's editorial
//      voice and the product feature in one move
//   5. The Standard — three short principles applied to digital
//   6. The Studio — closing colophon with address and a quiet sign-off
//
// The Manifesto sample is the centrepiece. Framed as a vellum certificate
// (cream-on-cream with brass border-rule and corner ornaments) so it reads
// as an artefact rather than another page section.
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ManifestoArtefact from '../components/ManifestoArtefact.astro';
import { BrassRule } from '@atelier/ui';
import { ChevronRight } from 'lucide-react';
import { RevealOnScroll } from '../components/RevealOnScroll.jsx';
import { StudioChronicle } from '../components/StudioChronicle.jsx';
import { PrinciplesPanel } from '../components/PrinciplesPanel.jsx';
---

<Base title="About — Atelier" description="Atelier is a house for the considered wardrobe. A private studio that reads what you own, composes from what you already have, and writes the manifesto of how you dress.">
  <Nav />
  <main>
    {/* ── 1. Hero ───────────────────────────────────────────────────── */}
    <section
      class="relative text-center flex flex-col items-center justify-center"
      style="min-height: 88vh; padding-top: clamp(7rem, 12vw, 10rem); padding-bottom: clamp(3rem, 5vw, 5rem); padding-inline: var(--atelier-page-padding);"
    >
      {/* Soft brass atmosphere — same motif as the home and pricing heroes */}
      <div
        aria-hidden="true"
        class="absolute pointer-events-none"
        style="top: 10%; left: 50%; transform: translateX(-50%); width: 60%; height: 50%; background: radial-gradient(ellipse at center, rgba(212, 179, 120, 0.07) 0%, transparent 65%);"
      />

      <div
        class="relative w-full mx-auto"
        style="max-width: var(--atelier-container-max);"
      >
        <div class="flex items-center justify-center gap-4 mb-6">
          <BrassRule client:load />
          <p
            class="text-[10px] uppercase font-medium"
            style="letter-spacing: 0.32em; color: var(--atelier-brass-600);"
          >
            The House · MMXXVI
          </p>
          <BrassRule client:load />
        </div>

        <h1
          class="mx-auto"
          style="font-family: var(--atelier-font-display); font-size: clamp(2.5rem, 6vw, 5rem); line-height: 1.02; letter-spacing: -0.015em; color: var(--atelier-stone-900); max-width: 18ch; margin-bottom: clamp(1.5rem, 2.5vw, 2rem);"
        >
          A house for the <em style="font-weight: 400;">considered</em> wardrobe.
        </h1>

        <p
          class="mx-auto"
          style="color: var(--atelier-stone-500); font-size: clamp(1.0625rem, 1.4vw, 1.25rem); line-height: 1.6; max-width: 56ch;"
        >
          Atelier is the digital equivalent of a fitting-room mirror, a stylist's
          notebook, and a curator's ledger — kept privately, used daily, composed
          with the same care a fashion house gives a collection.
        </p>

        {/* Scroll cue */}
        <div class="mt-14 flex flex-col items-center gap-2">
          <span
            class="text-[10px] uppercase"
            style="letter-spacing: 0.3em; color: var(--atelier-stone-400);"
          >
            Read on
          </span>
          <span
            aria-hidden="true"
            style="display: inline-block; width: 1px; height: 28px; background: linear-gradient(to bottom, var(--atelier-stone-300), transparent);"
          />
        </div>
      </div>
    </section>

    {/* ── 2. The Question ──────────────────────────────────────────── */}
    <section
      class="mx-auto"
      style="max-width: 760px; padding-inline: var(--atelier-page-padding); padding-bottom: clamp(4rem, 7vw, 6rem);"
    >
      <div class="flex items-center gap-3 mb-6">
        <BrassRule client:load />
        <p
          class="text-[10px] uppercase font-semibold"
          style="letter-spacing: 0.28em; color: var(--atelier-stone-500);"
        >
          Where we began
        </p>
      </div>
      <RevealOnScroll client:visible>
        <h2
          class="mb-8"
          style="font-family: var(--atelier-font-display); font-size: clamp(1.75rem, 3vw, 2.5rem); line-height: 1.15; letter-spacing: -0.01em; color: var(--atelier-stone-900); max-width: 22ch;"
        >
          It started with a private question.
        </h2>
      </RevealOnScroll>
      <div
        class="space-y-6"
        style="font-size: 1.0625rem; line-height: 1.75; color: var(--atelier-stone-700);"
      >
        <p>
          What would it look like to treat a personal wardrobe the way a fashion
          house treats a collection — every piece accounted for, every look
          composed with intention, every investment understood for what it
          returns?
        </p>
        <p>
          Closets are the most expensive rooms most of us own. The contents are
          chosen carefully, then forgotten about by mid-afternoon. The pieces we
          love most go unworn because we have stopped seeing them. The pieces we
          regret stay in the rotation because they are visible. The system that
          should be a private library of how we dress has, for most of us,
          become a small daily failure of attention.
        </p>
        <p>
          Atelier exists because that failure is not, in fact, a failure of
          taste. It is a failure of <em>tooling</em>. A wardrobe that knew
          itself — what was in it, what had been worn, what worked together —
          could quietly fix what no amount of additional shopping has fixed.
        </p>
      </div>
    </section>

    {/* ── 3. The Practice ──────────────────────────────────────────── */}
    <section
      class="mx-auto"
      style="max-width: 760px; padding-inline: var(--atelier-page-padding); padding-bottom: clamp(4rem, 7vw, 6rem);"
    >
      <div class="flex items-center gap-3 mb-6">
        <BrassRule client:load />
        <p
          class="text-[10px] uppercase font-semibold"
          style="letter-spacing: 0.28em; color: var(--atelier-stone-500);"
        >
          The Practice
        </p>
      </div>
      <RevealOnScroll client:visible>
        <h2
          class="mb-8"
          style="font-family: var(--atelier-font-display); font-size: clamp(1.75rem, 3vw, 2.5rem); line-height: 1.15; letter-spacing: -0.01em; color: var(--atelier-stone-900); max-width: 24ch;"
        >
          What goes on inside the studio.
        </h2>
      </RevealOnScroll>
      <div
        class="space-y-6"
        style="font-size: 1.0625rem; line-height: 1.75; color: var(--atelier-stone-700);"
      >
        <p>
          You sign in and your closet is on the page. Every garment you've added
          — brand, material, the day you bought it, the days you've worn it —
          sits there as a quiet inventory. The Concierge, a private stylist who
          has read it all, is available for the questions a real stylist would
          answer: what do I wear today, what should I pack, what's missing,
          what should I let go of.
        </p>
        <p>
          When you don't feel like composing, the Concierge does. One tap and a
          head-to-toe outfit appears, drawn from your collection, with the
          reasoning attached. Wear it, save it, or send it back. The
          intelligence improves with the years of wears you log.
        </p>
        <p>
          And once a season, Atelier writes you a <em>Style Manifesto</em> — a
          private three-paragraph reading of your aesthetic, composed entirely
          from how you actually dress. Not a personality test. A piece of
          editorial criticism about your own closet, written for you alone.
        </p>
      </div>
    </section>

    {/* ── 3.25 The Chronicle — heritage moment ──────────────────────
        Editorial heritage component. Even though Atelier is young, a
        chronicle asserts the brand exists IN TIME — a luxury-branding
        staple. Roman-numeral dated entries fade and lift in sequence
        as the section enters view. Edit the ENTRIES array in
        StudioChronicle.jsx to reflect real milestones as they land. */}
    <StudioChronicle client:visible />

    {/* ── 3.5 For Whom — audience qualifier ──────────────────────────
        Three "For the…" lines that qualify the reader in or out
        clearly. Closing distinction (not for those who want more,
        for those who want less used better) gives the section its
        edge. Sits between The Practice (what we do) and the Manifesto
        sample (proof of it) — logical flow: what → who → example. */}
    <section
      class="mx-auto"
      style="max-width: 760px; padding-inline: var(--atelier-page-padding); padding-bottom: clamp(4rem, 7vw, 6rem);"
    >
      <div class="flex items-center gap-3 mb-6">
        <BrassRule client:load />
        <p
          class="text-[10px] uppercase font-semibold"
          style="letter-spacing: 0.28em; color: var(--atelier-stone-500);"
        >
          For Whom
        </p>
      </div>
      <RevealOnScroll client:visible>
        <h2
          class="mb-8"
          style="font-family: var(--atelier-font-display); font-size: clamp(1.75rem, 3vw, 2.5rem); line-height: 1.15; letter-spacing: -0.01em; color: var(--atelier-stone-900); max-width: 24ch;"
        >
          For the considered closet.
        </h2>
      </RevealOnScroll>
      <div
        class="space-y-6"
        style="font-size: 1.0625rem; line-height: 1.75; color: var(--atelier-stone-700);"
      >
        <p>
          For the reader who asks <em>how many times will I wear this</em> before
          the price. For the owner of forty pieces, not four hundred. For the
          dresser who reaches for what they own first.
        </p>
        <p>
          Atelier is not for the person who wants more clothes.
          <em>It is for the person who wants less, used better.</em>
        </p>
      </div>
    </section>

    {/* ── 4. A Style Manifesto — embedded sample ─────────────────────
        The centrepiece. Framed as a vellum certificate so it reads as
        an artefact rather than another page section. Sample is for a
        fictional member named Lena to keep the framing honest. */}
    <section
      class="mx-auto"
      style="max-width: var(--atelier-container-max); padding-inline: var(--atelier-page-padding); padding-bottom: clamp(4rem, 7vw, 6rem);"
    >
      <div class="text-center mb-12">
        <div class="flex items-center justify-center gap-3 mb-4">
          <BrassRule client:load />
          <p
            class="text-[10px] uppercase font-medium"
            style="letter-spacing: 0.32em; color: var(--atelier-brass-600);"
          >
            A Manifesto · By way of example
          </p>
          <BrassRule client:load />
        </div>
        <h2
          class="mx-auto"
          style="font-family: var(--atelier-font-display); font-size: clamp(1.75rem, 3vw, 2.5rem); line-height: 1.1; letter-spacing: -0.01em; color: var(--atelier-stone-900); max-width: 28ch;"
        >
          One we composed for a fictional member.
        </h2>
        <p
          class="mx-auto mt-5"
          style="font-size: 0.9375rem; color: var(--atelier-stone-500); max-width: 52ch; line-height: 1.65;"
        >
          Every member receives a private brief — a three-movement reading of
          their aesthetic, written from their wardrobe data. This one was
          composed for a fictional member, Lena, who reads colour as
          architecture.
        </p>
      </div>

      {/* The vellum certificate — extracted into ManifestoArtefact.astro
          so /about and /manifesto share one source. */}
      <ManifestoArtefact />

      <p
        class="text-center mt-8"
        style="font-size: 0.8125rem; color: var(--atelier-stone-400); font-style: italic; max-width: 48ch; margin-inline: auto; line-height: 1.6;"
      >
        Your own manifesto is composed from your wardrobe, your wears, and the
        looks you've saved. Members receive a refreshed brief each season.
      </p>
    </section>

    {/* ── 5. The Standard ──────────────────────────────────────────── */}
    <section
      class="mx-auto"
      style="max-width: var(--atelier-container-max); padding-inline: var(--atelier-page-padding); padding-bottom: clamp(4rem, 7vw, 6rem);"
    >
      <div class="text-center mb-12">
        <div class="flex items-center justify-center gap-3 mb-4">
          <BrassRule client:load />
          <p
            class="text-[10px] uppercase font-semibold"
            style="letter-spacing: 0.28em; color: var(--atelier-stone-500);"
          >
            What we stand for
          </p>
          <BrassRule client:load />
        </div>
        <h2
          class="mx-auto"
          style="font-family: var(--atelier-font-display); font-size: clamp(1.75rem, 3vw, 2.5rem); line-height: 1.1; letter-spacing: -0.01em; color: var(--atelier-stone-900); max-width: 22ch;"
        >
          Quiet luxury, applied to software.
        </h2>
      </div>

      {/* Three principles — numbered, brass-tinted, scroll-revealed in
          sequence with a brass hairline that draws beneath each title as
          the principle arrives. Content lives in the PRINCIPLES array
          inside PrinciplesPanel.jsx — edit there to update copy. */}
      <PrinciplesPanel client:visible />
    </section>

    {/* ── 5.5 The Maker — founder presence ──────────────────────────
        Two-column on desktop: framed photo on the left, first-person
        founder copy on the right. Stacks on mobile. The photo carries
        the same vellum-card vocabulary as the Founding card on
        /pricing — white matte, brass border-rule, brass corner
        ornaments — so the brand mark frames the founder consistently
        with how it frames the founding offer. Photo is B&W via CSS
        filter (grayscale + slight contrast bump) for editorial tone;
        reversible if colour is preferred later. Closes the trust gap
        every premium brand closes by attaching a human — Aesop has
        Paphitis, Loewe has Anderson, Atelier has Sibylle.

        TODO when ready: commission a real Chanel-style architectural
        line drawing of The Long Barn from a luxury illustrator (Etsy
        has many — search 'single-line architectural illustration
        commission'). Place it as a small brand mark somewhere in
        this section, beside or beneath the signature line. */}
    <section
      class="mx-auto"
      style="max-width: 1080px; padding-inline: var(--atelier-page-padding); padding-bottom: clamp(4rem, 7vw, 6rem);"
    >
      <div class="flex items-center gap-3 mb-6">
        <BrassRule client:load />
        <p
          class="text-[10px] uppercase font-semibold"
          style="letter-spacing: 0.28em; color: var(--atelier-stone-500);"
        >
          The Maker
        </p>
      </div>
      <RevealOnScroll client:visible>
        <h2
          class="mb-10"
          style="font-family: var(--atelier-font-display); font-size: clamp(1.75rem, 3vw, 2.5rem); line-height: 1.15; letter-spacing: -0.01em; color: var(--atelier-stone-900); max-width: 26ch;"
        >
          Atelier is composed by <em style="font-weight: 400;">Sibylle Möller-Sherwood</em>.
        </h2>
      </RevealOnScroll>

      {/* Two-column: framed photo (left on desktop) + prose (right) */}
      <div class="grid grid-cols-1 md:grid-cols-[minmax(0,360px)_1fr] gap-10 md:gap-14 items-start mb-10">
        {/* Photo column — vellum-card frame matching the Founding card
            on /pricing. White matte (14px padding), inner brass border-
            rule, four brass corner ornaments. The photo itself is B&W
            via CSS filter for editorial tone. */}
        <RevealOnScroll client:visible>
          <figure style="margin: 0;">
            <div
              style="position: relative; padding: 14px; background: #ffffff; border: 1px solid var(--atelier-stone-200); border-radius: 4px; box-shadow: 0 30px 70px -30px rgba(28, 25, 23, 0.18), 0 8px 20px -8px rgba(28, 25, 23, 0.08);"
            >
              <img
                src="/about/sibylle.png"
                alt="Sibylle Möller-Sherwood, founder of Atelier"
                loading="lazy"
                style="display: block; width: 100%; height: auto; filter: grayscale(0.9) contrast(1.05); border-radius: 2px; position: relative; z-index: 0;"
              />
              {/* Brass border-rule — sits on the white matte between the
                  photo edge and the outer card edge */}
              <div
                aria-hidden="true"
                style="position: absolute; inset: 6px; border: 1px solid rgba(212, 179, 120, 0.4); pointer-events: none; border-radius: 2px; z-index: 1;"
              />
              {/* Brass corner ornaments — same vocabulary as the Founding
                  card on /pricing and the Manifesto certificate */}
              <span aria-hidden="true" style="position: absolute; width: 5px; height: 5px; background: var(--atelier-brass-600); border-radius: 1px; top: 2px; left: 2px; z-index: 2;" />
              <span aria-hidden="true" style="position: absolute; width: 5px; height: 5px; background: var(--atelier-brass-600); border-radius: 1px; top: 2px; right: 2px; z-index: 2;" />
              <span aria-hidden="true" style="position: absolute; width: 5px; height: 5px; background: var(--atelier-brass-600); border-radius: 1px; bottom: 2px; left: 2px; z-index: 2;" />
              <span aria-hidden="true" style="position: absolute; width: 5px; height: 5px; background: var(--atelier-brass-600); border-radius: 1px; bottom: 2px; right: 2px; z-index: 2;" />
            </div>
            <figcaption
              style="margin-top: 1rem; text-align: center; font-family: var(--atelier-font-display); font-style: italic; font-size: 0.875rem; color: var(--atelier-stone-500); letter-spacing: 0.02em;"
            >
              Sibylle Möller-Sherwood · MMXXVI
            </figcaption>
          </figure>
        </RevealOnScroll>

        {/* Prose column — first-person founder voice. Four paragraphs:
            credentials as character; personal fashion background; origin
            moment (the husband's question); studio + business status. */}
        <div
          class="space-y-6"
          style="font-size: 1.0625rem; line-height: 1.75; color: var(--atelier-stone-700);"
        >
          <p>
            Technology has been my profession for the whole of my working
            life: twenty years of building systems as a project and product
            manager. Most recently as a Head of Data and Systems, latterly
            through my own studio Talastron, founded in 2024. Microsoft
            platforms, data systems, the steady work of getting large systems
            to behave: that has been my craft for as long as I've had one.
          </p>
          <p>
            Atelier began at the other end of my life. I have always loved
            fashion and, when I could afford it, invested in pieces meant to
            last. The wardrobe I've quietly built over the years was not one
            I wanted to replace each season.
          </p>
          <p>
            Atelier started before a summer trip. My husband and I sat down
            one Saturday to plan what we'd both pack. He could tell me his
            wardrobe in two minutes: three trousers, four shirts, the
            jacket. I could not. Not properly. That gap, between a closet of
            carefully-chosen pieces and a head that couldn't quite see them
            all at once, turned out to be a tool that didn't yet exist. So I
            built one. For myself first. Then for the friends I showed it
            to. Now for anyone who, like me, wants less, used better.
          </p>
          <p>
            The studio sits in a converted barn in Cobham, Surrey, run with
            the help of a small team and a great deal of cashmere. We are
            privately held and self-funded. No investor in the closet. The
            product is the business.
          </p>
        </div>
      </div>

      {/* Hand-signed name as a flourish — typeset in italic display
          serif rather than a real signature for now. */}
      <div class="flex items-center gap-4">
        <span
          aria-hidden="true"
          style="display: inline-block; width: 32px; height: 1.5px; background: var(--atelier-brass-300);"
        />
        <p
          class="italic"
          style="font-family: var(--atelier-font-display); font-size: 1.25rem; color: var(--atelier-stone-700); letter-spacing: -0.005em;"
        >
          — Sibylle
        </p>
        <a
          href="mailto:contact@myatelier.style"
          class="text-[11px] uppercase ml-auto transition-colors hover:text-stone-900"
          style="letter-spacing: 0.28em; color: var(--atelier-stone-500); font-weight: 500;"
        >
          Letters →
        </a>
      </div>
    </section>

    {/* ── 6. Closing — invitation to the studio ────────────────────── */}
    <section
      class="mx-auto"
      style="max-width: 720px; padding-inline: var(--atelier-page-padding); padding-bottom: clamp(5rem, 8vw, 7rem); text-align: center;"
    >
      <div class="flex items-center justify-center gap-3 mb-6">
        <BrassRule client:load />
        <p
          class="text-[10px] uppercase font-medium"
          style="letter-spacing: 0.32em; color: var(--atelier-brass-600);"
        >
          The Invitation
        </p>
        <BrassRule client:load />
      </div>
      <RevealOnScroll client:visible>
        <h2
          class="mx-auto mb-6"
          style="font-family: var(--atelier-font-display); font-size: clamp(1.875rem, 3.5vw, 2.75rem); line-height: 1.1; letter-spacing: -0.01em; color: var(--atelier-stone-900); max-width: 22ch;"
        >
          Step inside the studio.
        </h2>
      </RevealOnScroll>
      <p
        class="mx-auto mb-8"
        style="font-size: 1rem; line-height: 1.65; color: var(--atelier-stone-500); max-width: 50ch;"
      >
        Begin with a fourteen-day trial. Read your own manifesto inside.
      </p>
      <a
        href="/pricing"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-full text-base font-semibold transition-all hover:opacity-90 active:scale-[0.98]"
        style="background: var(--atelier-stone-900); color: #ffffff; letter-spacing: 0.04em; box-shadow: 0 12px 32px -10px rgba(28, 25, 23, 0.3);"
      >
        Find the keys
        <ChevronRight size={16} strokeWidth={1.75} client:load />
      </a>
    </section>
  </main>
  <Footer />
</Base>

