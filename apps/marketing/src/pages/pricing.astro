---
// apps/marketing/src/pages/pricing.astro
//
// "The Keys to Atelier" — the editorial home for the brand phrase.
//
// Structure:
//   1. Hero — eyebrow, the brand-phrase headline, considered subhead, trial line
//   2. Pricing cards — Monthly + Annual side by side, Annual visually featured
//   3. What's inside — six short lines that justify the price by naming what
//      membership actually unlocks (the Concierge, the Lookbook, etc.)
//   4. Trust line — refund + cancel + VAT, set quietly at the base
//
// The hero takes a full first viewport (`min-height: 90vh`) so the brand
// phrase has the room to land before any pricing pressure hits.
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { BrassRule } from '@atelier/ui';
import { PricingInsideList } from '../components/PricingInsideList.jsx';
import { ChevronRight } from 'lucide-react';

// Lemon Squeezy product URL (Atelier Membership — covers both Monthly & Annual variants).
// The customer picks Monthly vs Annual on the LS-hosted checkout page.
// Annual is set as the "favourite" / highlighted default in the LS dashboard.
const LS_CHECKOUT_URL = 'https://myatelier.lemonsqueezy.com/checkout/buy/a9d33c73-c40d-41b7-bb39-6aef6b39b525';

// Founding Member URL — same Annual variant as LS_CHECKOUT_URL, with the
// KYMDE3NG discount code (£29 off forever, capped at 100 redemptions in LS)
// pre-applied via the ?discount= param. Customers see £108 − £29 = £79/year
// on the checkout page without typing anything. When the 100-redemption cap
// is hit, LS auto-rejects further redemptions — the URL still loads but the
// discount stops applying. Watch the redemption count in LS during launch
// and swap this section out (or hide it) before customer #101 lands.
const LS_FOUNDING_URL = 'https://myatelier.lemonsqueezy.com/checkout/buy/a9d33c73-c40d-41b7-bb39-6aef6b39b525?discount=KYMDE3NG';

// Variant IDs — appear in webhook payloads; reference only, not used in URLs.
// 1809234 = Monthly, 1809222 = Annual (Founding members come in as Annual
// + the KYMDE3NG discount, so they're indistinguishable from regular Annual
// in the webhook payload's variant_id field).
---

<Base title="The Keys to Atelier — Membership">
  <Nav />
  <main>
    {/* ── Hero: The Keys to Atelier ────────────────────────────────── */}
    <section
      class="relative text-center flex flex-col items-center justify-center"
      style="min-height: 90vh; padding-top: clamp(7rem, 12vw, 10rem); padding-bottom: clamp(3rem, 5vw, 5rem); padding-inline: var(--atelier-page-padding);"
    >
      {/* Soft brass atmosphere — same motif as the home hero, ties the
          two pages together as one studio. */}
      <div
        aria-hidden="true"
        class="absolute pointer-events-none"
        style="top: 10%; left: 50%; transform: translateX(-50%); width: 60%; height: 50%; background: radial-gradient(ellipse at center, rgba(212, 179, 120, 0.07) 0%, transparent 65%);"
      />

      <div
        class="relative w-full mx-auto"
        style="max-width: var(--atelier-container-max);"
      >
        {/* Editorial mast */}
        <div class="flex items-center justify-center gap-4 mb-6">
          <BrassRule client:load />
          <p
            class="text-[10px] uppercase font-medium"
            style="letter-spacing: 0.32em; color: var(--atelier-brass-600);"
          >
            Membership · MMXXVI
          </p>
          <BrassRule client:load />
        </div>

        {/* The brand-phrase headline. Period at the end so it lands like a
            statement, not an invitation banner. */}
        <h1
          class="mx-auto"
          style="font-family: var(--atelier-font-display); font-size: clamp(2.5rem, 6vw, 5.5rem); line-height: 1.02; letter-spacing: -0.015em; color: var(--atelier-stone-900); max-width: 14ch; margin-bottom: clamp(1.5rem, 2.5vw, 2rem);"
        >
          The <em style="font-weight: 400;">Keys</em> to Atelier.
        </h1>

        {/* Considered subhead — what membership actually means, written so
            it reads as a letter from the studio rather than a pitch. */}
        <p
          class="mx-auto"
          style="color: var(--atelier-stone-500); font-size: clamp(1.0625rem, 1.4vw, 1.25rem); line-height: 1.6; max-width: 54ch; margin-bottom: clamp(1.75rem, 2.5vw, 2.25rem);"
        >
          An invitation to the studio. A private stylist on call, your considered closet
          finally on the page, and the small luxuries that turn a wardrobe into a practice.
        </p>

        {/* Trial line — small, factual. Lemon Squeezy collects card details
            at checkout, so we don't claim otherwise. */}
        <p
          class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full"
          style="background: rgba(212, 179, 120, 0.12); border: 1px solid rgba(212, 179, 120, 0.3); color: var(--atelier-brass-600); font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; font-weight: 600;"
        >
          <span
            aria-hidden="true"
            style="width: 5px; height: 5px; border-radius: 50%; background: var(--atelier-brass-600);"
          />
          14-day trial
        </p>
      </div>
    </section>

    {/* ── Founding Members — the launch tier ───────────────────────────
        Limited to the first 100 members. £79/year, locked at that price
        for life. Set as a vellum-card flourish so it reads as a printed
        invitation rather than a discount banner — same vocabulary as
        the Manifesto and Annual Report artefacts.

        Implemented as the KYMDE3NG discount code on the Annual variant
        (£29 off forever, 100 redemption cap in LS). When the cap closes,
        LS auto-rejects further redemptions — this section should be
        hidden via a single conditional or replaced with a quiet
        "Founding Members closed — join us at the public price below"
        line, otherwise customer #101 sees a checkout with the discount
        silently dropped. */}
    <section
      class="mx-auto"
      style="max-width: 720px; padding-inline: var(--atelier-page-padding); padding-bottom: clamp(3rem, 5vw, 4rem);"
    >
      <article
        class="relative"
        style="background: #ffffff; border: 1px solid var(--atelier-stone-200); border-radius: 4px; padding: clamp(2rem, 4vw, 3rem) clamp(1.75rem, 3.5vw, 2.75rem); box-shadow: 0 50px 120px -30px rgba(28, 25, 23, 0.12), 0 18px 40px -16px rgba(28, 25, 23, 0.08);"
      >
        {/* Brass border-rule frame inside the card */}
        <div
          aria-hidden="true"
          style="position: absolute; inset: 14px; border: 1px solid rgba(212, 179, 120, 0.35); pointer-events: none; border-radius: 2px;"
        />

        {/* Corner ornaments — same flourish as Manifesto + Annual Report */}
        <span aria-hidden="true" class="founding-corner" style="top: 10px; left: 10px;" />
        <span aria-hidden="true" class="founding-corner" style="top: 10px; right: 10px;" />
        <span aria-hidden="true" class="founding-corner" style="bottom: 10px; left: 10px;" />
        <span aria-hidden="true" class="founding-corner" style="bottom: 10px; right: 10px;" />

        <div class="relative text-center">
          {/* Eyebrow */}
          <div class="flex items-center justify-center gap-3 mb-5">
            <span
              aria-hidden="true"
              style="display: inline-block; width: 24px; height: 1.5px; background: var(--atelier-brass-300);"
            />
            <p
              class="text-[10px] uppercase font-semibold"
              style="letter-spacing: 0.4em; color: var(--atelier-brass-600);"
            >
              Founding Members
            </p>
            <span
              aria-hidden="true"
              style="display: inline-block; width: 24px; height: 1.5px; background: var(--atelier-brass-300);"
            />
          </div>

          {/* Headline */}
          <h2
            class="mx-auto mb-4"
            style="font-family: var(--atelier-font-display); font-size: clamp(1.625rem, 2.75vw, 2.25rem); line-height: 1.1; letter-spacing: -0.01em; color: var(--atelier-stone-900); max-width: 22ch;"
          >
            For the <em style="font-weight: 400;">first one hundred</em>.
          </h2>

          {/* Considered subhead */}
          <p
            class="mx-auto mb-7"
            style="font-style: italic; font-family: var(--atelier-font-display); font-size: clamp(0.9375rem, 1.2vw, 1.0625rem); line-height: 1.65; color: var(--atelier-stone-600); max-width: 48ch;"
          >
            The studio opens with a one-time invitation. The first one hundred
            members take the keys at a founding price, kept locked at that
            price for as long as they remain.
          </p>

          {/* Price moment */}
          <div class="flex flex-col items-center mb-7">
            <div class="flex items-baseline gap-2.5 mb-2">
              <span
                style="font-family: var(--atelier-font-display); font-size: clamp(2.75rem, 5vw, 3.75rem); line-height: 1; color: var(--atelier-stone-900); letter-spacing: -0.015em;"
              >
                £79
              </span>
              <span style="font-size: 0.9375rem; color: var(--atelier-stone-500);">/ year, locked for life</span>
            </div>
            <p
              class="text-[10px] uppercase"
              style="letter-spacing: 0.32em; color: var(--atelier-stone-400); font-weight: 500;"
            >
              vs £108 public price · save £29 every year
            </p>
          </div>

          {/* CTA */}
          <a
            href={LS_FOUNDING_URL}
            class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-full text-base font-semibold transition-all hover:opacity-90 active:scale-[0.98]"
            style="background: var(--atelier-brass-300); color: var(--atelier-stone-900); letter-spacing: 0.04em; box-shadow: 0 12px 32px -10px rgba(212, 179, 120, 0.4);"
          >
            Claim a founding key
            <ChevronRight size={16} strokeWidth={1.75} client:load />
          </a>

          {/* Scarcity note — manual today, dynamic once webhook reports
              the live remaining count */}
          <p
            class="mt-6 text-[10px] uppercase"
            style="letter-spacing: 0.32em; color: var(--atelier-brass-600); font-weight: 600;"
          >
            Limited to the first 100 · then withdrawn
          </p>
        </div>
      </article>
    </section>

    {/* Quiet section divider so the Public pricing reads as the secondary
        offering, not competing with the Founding card above */}
    <div class="text-center mb-10">
      <p
        class="text-[10px] uppercase"
        style="letter-spacing: 0.32em; color: var(--atelier-stone-400); font-weight: 500;"
      >
        Or join at the public price
      </p>
    </div>

    {/* ── Pricing cards ─────────────────────────────────────────────── */}
    <section
      class="mx-auto"
      style="max-width: 920px; padding-inline: var(--atelier-page-padding); padding-bottom: clamp(4rem, 7vw, 6rem);"
    >
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        {/* ── Monthly ── flexible, no commitment */}
        <article
          class="relative p-8 md:p-10 flex flex-col"
          style="background: #ffffff; border: 1px solid var(--atelier-stone-200); border-radius: 24px; box-shadow: 0 30px 70px -30px rgba(28, 25, 23, 0.12);"
        >
          <div class="mb-8">
            <p
              class="text-[10px] uppercase font-semibold mb-3"
              style="letter-spacing: 0.28em; color: var(--atelier-stone-500);"
            >
              Monthly
            </p>
            <h2
              class="mb-2"
              style="font-family: var(--atelier-font-display); font-size: 1.625rem; color: var(--atelier-stone-900); letter-spacing: -0.005em;"
            >
              Flexible, no commitment.
            </h2>
            <p class="text-sm" style="color: var(--atelier-stone-500); line-height: 1.55;">
              Pause, change your mind, come back. The studio is here whenever you are.
            </p>
          </div>

          <div class="mb-8 flex items-baseline gap-2">
            <span
              style="font-family: var(--atelier-font-display); font-size: 3rem; line-height: 1; color: var(--atelier-stone-900);"
            >
              £12
            </span>
            <span class="text-sm" style="color: var(--atelier-stone-500);">/ month</span>
          </div>

          <a
            href={LS_CHECKOUT_URL}
            class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-full text-sm font-medium transition-all hover:opacity-90 active:scale-[0.98] mt-auto"
            style="background: var(--atelier-stone-900); color: #ffffff; letter-spacing: 0.04em;"
          >
            Begin curating
            <ChevronRight size={16} strokeWidth={1.75} client:load />
          </a>
        </article>

        {/* ── Annual ── dark, featured. "The keys" recommended treatment.
             Sits 4px higher than Monthly via translateY on md+. */}
        <article
          class="relative p-8 md:p-10 flex flex-col overflow-hidden md:-translate-y-1"
          style="background: linear-gradient(160deg, var(--atelier-ink) 0%, #292524 100%); color: #ffffff; border-radius: 24px; box-shadow: 0 50px 120px -30px rgba(28, 25, 23, 0.5), 0 18px 50px -18px rgba(212, 179, 120, 0.18);"
        >
          {/* Featured ribbon */}
          <div
            class="absolute top-5 right-5 px-3 py-1 rounded-full text-[9px] uppercase font-semibold"
            style="background: var(--atelier-brass-300); color: var(--atelier-stone-900); letter-spacing: 0.22em;"
          >
            The Keys
          </div>

          <div class="mb-8">
            <p
              class="text-[10px] uppercase font-semibold mb-3"
              style="letter-spacing: 0.28em; color: var(--atelier-brass-300);"
            >
              Annual
            </p>
            <h2
              class="mb-2"
              style="font-family: var(--atelier-font-display); font-size: 1.625rem; color: #ffffff; letter-spacing: -0.005em;"
            >
              The considered choice.
            </h2>
            <p class="text-sm" style="color: rgba(255,255,255,0.65); line-height: 1.55;">
              Two months saved, the year ahead settled. The way most members stay.
            </p>
          </div>

          <div class="mb-2 flex items-baseline gap-2">
            <span
              style="font-family: var(--atelier-font-display); font-size: 3rem; line-height: 1; color: #ffffff;"
            >
              £108
            </span>
            <span class="text-sm" style="color: rgba(255,255,255,0.55);">/ year</span>
          </div>
          <p
            class="text-[11px] mb-8"
            style="color: var(--atelier-brass-300); letter-spacing: 0.06em;"
          >
            That's £9/month — save 25%.
          </p>

          <a
            href={LS_CHECKOUT_URL}
            class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-full text-sm font-semibold transition-all hover:opacity-90 active:scale-[0.98] mt-auto"
            style="background: var(--atelier-brass-300); color: var(--atelier-stone-900); letter-spacing: 0.04em;"
          >
            Begin curating
            <ChevronRight size={16} strokeWidth={1.75} client:load />
          </a>
        </article>
      </div>
    </section>

    {/* ── What's inside the studio ──────────────────────────────────── */}
    <section
      class="mx-auto"
      style="max-width: var(--atelier-container-max); padding-inline: var(--atelier-page-padding); padding-bottom: clamp(4rem, 7vw, 6rem);"
    >
      {/* Section header */}
      <div class="text-center mb-12">
        <div class="flex items-center justify-center gap-3 mb-4">
          <BrassRule client:load />
          <p
            class="text-[10px] uppercase font-medium"
            style="letter-spacing: 0.28em; color: var(--atelier-brass-600);"
          >
            Behind the keys
          </p>
          <BrassRule client:load />
        </div>
        <h2
          class="mx-auto"
          style="font-family: var(--atelier-font-display); font-size: clamp(1.75rem, 3vw, 2.5rem); line-height: 1.1; letter-spacing: -0.01em; color: var(--atelier-stone-900); max-width: 22ch;"
        >
          What membership unlocks.
        </h2>
      </div>

      {/* Two-column list of what's behind the keys. Lives in a React
          component because Astro's static analyser can't resolve dynamic
          icon imports inside a {map(...)} loop. */}
      <PricingInsideList />

    </section>

    {/* ── By Comparison — comparative anchor ─────────────────────────
        Quietly reframes £108/year against what comparable services
        cost. Premium products must justify their price, not just
        state it — Atelier is the cheapest considered-styling option
        on the page and visitors should know it. Set as an editorial
        aside rather than a comparison table; magazine-style ledger
        rather than a SaaS feature matrix. */}
    <section
      class="mx-auto"
      style="max-width: 720px; padding-inline: var(--atelier-page-padding); padding-bottom: clamp(4rem, 7vw, 6rem);"
    >
      <div class="text-center mb-10">
        <div class="flex items-center justify-center gap-3 mb-4">
          <BrassRule client:load />
          <p
            class="text-[10px] uppercase font-medium"
            style="letter-spacing: 0.32em; color: var(--atelier-brass-600);"
          >
            By comparison
          </p>
          <BrassRule client:load />
        </div>
        <h2
          class="mx-auto"
          style="font-family: var(--atelier-font-display); font-size: clamp(1.625rem, 2.5vw, 2rem); line-height: 1.15; letter-spacing: -0.005em; color: var(--atelier-stone-900); max-width: 22ch;"
        >
          What considered styling costs elsewhere.
        </h2>
      </div>

      {/* Comparison ledger — three rows, each with the alternative on
          the left and its price on the right. Hairlines between.
          Closes with an italic Atelier line beneath in brass. */}
      <div
        class="mx-auto"
        style="max-width: 560px;"
      >
        <ul
          class="flex flex-col"
          style="border-top: 1px solid var(--atelier-stone-200);"
        >
          <li
            class="flex items-baseline justify-between gap-6 py-4"
            style="border-bottom: 1px solid var(--atelier-stone-200);"
          >
            <span style="font-family: var(--atelier-font-display); font-size: 1rem; color: var(--atelier-stone-700);">
              A single personal styling appointment
            </span>
            <span
              class="shrink-0 text-[11px] uppercase font-semibold"
              style="letter-spacing: 0.22em; color: var(--atelier-stone-500); font-variant-numeric: tabular-nums;"
            >
              £200 and up
            </span>
          </li>
          <li
            class="flex items-baseline justify-between gap-6 py-4"
            style="border-bottom: 1px solid var(--atelier-stone-200);"
          >
            <span style="font-family: var(--atelier-font-display); font-size: 1rem; color: var(--atelier-stone-700);">
              Net&#8209;a&#8209;Porter EIP styling concierge
            </span>
            <span
              class="shrink-0 text-[11px] uppercase font-semibold"
              style="letter-spacing: 0.22em; color: var(--atelier-stone-500); font-variant-numeric: tabular-nums;"
            >
              By invitation
            </span>
          </li>
          <li
            class="flex items-baseline justify-between gap-6 py-4"
            style="border-bottom: 1px solid var(--atelier-stone-200);"
          >
            <span style="font-family: var(--atelier-font-display); font-size: 1rem; color: var(--atelier-stone-700);">
              A capsule wardrobe consultation
            </span>
            <span
              class="shrink-0 text-[11px] uppercase font-semibold"
              style="letter-spacing: 0.22em; color: var(--atelier-stone-500); font-variant-numeric: tabular-nums;"
            >
              £350 — £800
            </span>
          </li>
          {/* Atelier row — set differently so it lands as the answer */}
          <li
            class="flex items-baseline justify-between gap-6 py-5"
            style="border-bottom: 1px solid var(--atelier-stone-200); background: rgba(212, 179, 120, 0.06);"
          >
            <span style="font-family: var(--atelier-font-display); font-size: 1rem; color: var(--atelier-stone-900); font-weight: 500;">
              <em style="font-weight: 400;">Atelier</em>, a year inside the studio
            </span>
            <span
              class="shrink-0 text-[11px] uppercase font-semibold"
              style="letter-spacing: 0.22em; color: var(--atelier-brass-600); font-variant-numeric: tabular-nums;"
            >
              £108
            </span>
          </li>
        </ul>

        {/* Italic closing line — repositions the number */}
        <p
          class="text-center mt-6 italic"
          style="font-family: var(--atelier-font-display); font-size: 0.9375rem; color: var(--atelier-stone-500); line-height: 1.6; max-width: 46ch; margin-inline: auto;"
        >
          Less than half of one stylist visit — for a stylist who never closes,
          composed from the wardrobe you already own.
        </p>
      </div>
    </section>

    {/* ── Trust line — quiet, factual, at the base ─────────────────── */}
    <div
      class="mx-auto text-center"
      style="max-width: 600px; padding-inline: var(--atelier-page-padding); padding-bottom: clamp(4rem, 6vw, 5rem);"
    >
      <p
        class="text-[11px] uppercase"
        style="letter-spacing: 0.22em; color: var(--atelier-stone-400);"
      >
        30-day no-questions-asked refund · cancel anytime · VAT included where applicable
      </p>
    </div>
  </main>
  <Footer />
</Base>

<style>
  /* Brass corner ornaments on the Founding Member card — same vocabulary
     as the Manifesto certificate on /about and /manifesto. */
  .founding-corner {
    position: absolute;
    width: 5px;
    height: 5px;
    background: var(--atelier-brass-600);
    border-radius: 1px;
  }
</style>
